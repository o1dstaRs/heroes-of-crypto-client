{
    "name": "heroes-of-crypto-client",
    "private": true,
    "description": "The web3 turn-based strategy game for the browser",
    "keywords": [
        "web3",
        "game",
        "turn-based",
        "strategy",
        "browser",
        "ethereum"
    ],
    "homepage": "https://heroesofcrypto.io",
    "repository": {
        "type": "git",
        "url": "https://github.com/o1dstaRs/heroes-of-crypto-client.git"
    },
    "license": "MIT",
    "workspaces": [
        "game/heroes-of-crypto-common",
        "game/core"
    ],
    "scripts": {
        "build": "bun run lint:fix && bun run lint && bun run build:ws",
        "build:common": "bun run --cwd game/heroes-of-crypto-common build",
        "build:core": "bun run --cwd game/core build",
        "build:game": "bun workspace @heroesofcrypto/common build && bun workspace @heroesofcrypto/core build",
        "build:ws": "bun run build:common && bun run build:core",
        "lint": "bun run lint:es && bun run lint:scss && bun run lint:package && bun run lint:style",
        "lint:es": "bunx eslint \"game/**/src/**/*.{ts,tsx}\" --ignore-pattern .prettierignore",
        "lint:es:fix": "bun run lint:es -- --fix",
        "lint:fix": "bun run lint:es:fix && bun run lint:scss:fix && bun run lint:package:fix && bun run lint:style:fix",
        "lint:package": "bun run lint:package:fix -- --check",
        "lint:package:fix": "bunx sort-package-json package.json \"game/*/package.json\"",
        "lint:scss": "bunx stylelint --ignore-path .prettierignore \"game/**/src/**/*.scss\"",
        "lint:scss:fix": "bun run lint:scss -- --fix",
        "lint:style": "bun run lint:style:base -- --check",
        "lint:style:base": "bunx prettier \"game/**/src/**/*.{ts,tsx,js,json,scss}\" \"game/*/*.{ts,tsx,js,json,scss}\"",
        "lint:style:fix": "bun run lint:style:base -- --write",
        "start": "bun --cwd game/core start"
    },
    "resolutions": {
        "@typescript-eslint/eslint-plugin": "^8.46.3",
        "@typescript-eslint/parser": "^8.46.3",
        "typescript": "^5.9"
    },
    "dependencies": {
        "@types/bun": "^1.3.2"
    },
    "devDependencies": {
        "@eslint/js": "^9.8.0",
        "@typescript-eslint/eslint-plugin": "^8.46.3",
        "@typescript-eslint/parser": "^8.46.3",
        "@vitejs/plugin-react": "^5.1.0",
        "buffer": "^6.0.3",
        "bun-types": "^1.3.2",
        "cpy-cli": "^4.0.0",
        "cross-env": "^7.0.3",
        "crypto-browserify": "^3.12.0",
        "eslint": "^9.16.0",
        "eslint-plugin-jsx-a11y": "^6.10.0",
        "eslint-plugin-react": "^7.37.1",
        "eslint-plugin-react-hooks": "^5.0.0",
        "events": "^3.3.0",
        "globals": "^15.13.0",
        "postcss": "^8.4.38",
        "postcss-scss": "^4.0.9",
        "prettier": "^3",
        "process": "^0.11.10",
        "rimraf": "^6.1.0",
        "sort-package-json": "^1.57.0",
        "stream-browserify": "^3.0.0",
        "string_decoder": "^1.3.0",
        "stylelint": "^16.8.2",
        "stylelint-scss": "^6.5.0",
        "svgo": "^3.3.2",
        "typescript": "^5.6",
        "vite": "^7.2.2",
        "vm-browserify": "^1.1.2"
    },
    "packageManager": "bun@^1.1.0",
    "engines": {
        "bun": ">=1.3.2"
    },
    "staticFiles": {
        "staticPath": "game/core/src/heroes/configuration"
    }
}
