{
    "name": "heroes-of-crypto-client",
    "private": true,
    "description": "The web3 turn-based strategy game for the browser",
    "keywords": [
        "web3",
        "game",
        "turn-based",
        "strategy",
        "browser",
        "ethereum"
    ],
    "homepage": "https://heroesofcrypto.io",
    "repository": {
        "type": "git",
        "url": "https://github.com/o1dstaRs/heroes-of-crypto-client.git"
    },
    "license": "MIT",
    "workspaces": [
        "game/heroes-of-crypto-common",
        "game/core",
        "game/mcp",
        "site"
    ],
    "scripts": {
        "build": "bun run lint:fix && bun run lint && bun run build:ws",
        "build:common": "bun run --cwd game/heroes-of-crypto-common build",
        "build:core": "bun run --cwd game/core build",
        "build:game": "bun workspace @heroesofcrypto/common build && bun workspace @heroesofcrypto/core build",
        "build:mcp": "bun run --cwd game/mcp build",
        "build:site": "bun run --cwd site build",
        "build:skip": "bun run --cwd game/core build:skip",
        "build:ws": "bun run build:common && bun run build:core && bun run build:site && bun run build:mcp",
        "lint": "bun run lint:es && bun run lint:scss && bun run lint:package && bun run lint:style",
        "lint:es": "bunx eslint \"game/**/src/**/*.{ts,tsx}\" --ignore-pattern .prettierignore",
        "lint:es:fix": "bun run lint:es -- --fix",
        "lint:fix": "bun run lint:es:fix && bun run lint:scss:fix && bun run lint:package:fix && bun run lint:style:fix",
        "lint:package": "bun run lint:package:fix -- --check",
        "lint:package:fix": "bunx sort-package-json package.json \"game/*/package.json\" site/package.json",
        "lint:scss": "bunx stylelint --ignore-path .prettierignore \"game/**/src/**/*.scss\"",
        "lint:scss:fix": "bun run lint:scss -- --fix",
        "lint:style": "bun run lint:style:base -- --check",
        "lint:style:base": "bunx prettier \"game/**/src/**/*.{ts,tsx,js,json,scss}\" \"game/*/*.{ts,tsx,js,json,scss}\"",
        "lint:style:fix": "bun run lint:style:base -- --write",
        "prepare": "git config core.hooksPath .githooks || true",
        "start": "bun --cwd game/core start",
        "start:site": "bun --cwd site dev"
    },
    "lint-staged": {
        "game/**/src/**/*.{ts,tsx}": [
            "bunx eslint --fix --ignore-pattern .prettierignore",
            "bunx prettier --write"
        ],
        "game/**/src/**/*.scss": [
            "bunx stylelint --fix --ignore-path .prettierignore",
            "bunx prettier --write"
        ],
        "game/**/src/**/*.{js,json}": [
            "bunx prettier --write"
        ],
        "{package.json,game/*/package.json,site/package.json}": [
            "bunx sort-package-json"
        ]
    },
    "resolutions": {
        "@typescript-eslint/eslint-plugin": "^8.61.1",
        "@typescript-eslint/parser": "^8.61.1",
        "typescript": "^5.9",
        "ws": "8.21.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@typescript-eslint/eslint-plugin": "^8.61.1",
        "@typescript-eslint/parser": "^8.61.1",
        "@vitejs/plugin-react": "^6.0.2",
        "@vitejs/plugin-react-swc": "^4.3.1",
        "buffer": "^6.0.3",
        "bun-types": "^1.3.14",
        "cpy-cli": "^7.0.0",
        "cross-env": "^7.0.3",
        "eslint": "^9.39.4",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^5.2.0",
        "events": "^3.3.0",
        "globals": "^15.15.0",
        "lint-staged": "^17.0.8",
        "postcss": "^8.5.15",
        "postcss-scss": "^4.0.9",
        "prettier": "^3.8.4",
        "process": "^0.11.10",
        "rimraf": "^6.1.3",
        "sort-package-json": "^3.7.1",
        "stylelint": "^17.13.0",
        "stylelint-scss": "^7.2.0",
        "svgo": "^3.3.3",
        "typescript": "^5.9.3",
        "vite": "^8.0.16"
    },
    "packageManager": "bun@^1.1.0",
    "engines": {
        "bun": ">=1.3.2"
    },
    "staticFiles": {
        "staticPath": "game/core/src/heroes/configuration"
    }
}
