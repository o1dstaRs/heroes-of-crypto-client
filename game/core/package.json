{
    "name": "@heroesofcrypto/core",
    "version": "0.1.5",
    "description": "Core game logic for Heroes of Crypto",
    "homepage": "https://heroesofcrypto.io",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "rimraf .parcel-cache && bun run build:images && rimraf dist && tsc && vite build",
        "build:docs": "rimraf ../../.parcel-cache && rimraf ../../docs/dist && dotenv -e .env.production parcel build --no-optimize src/ui/index.html --public-url . --no-source-maps && cpy dist ../../docs",
        "build:images": "rimraf images && bun run copy:images && npm run generate:animations && npm run generate:images",
        "build:skip": "rimraf .parcel-cache && rimraf dist && tsc && vite build",
        "copy:images": "cpy $HOC_IMAGES_LOC ./",
        "generate:animations": "bun scripts/generate_animation_atlases.js",
        "generate:images": "bun scripts/generate_image_imports.js",
        "start": "cross-env NODE_ENV=development vite"
    },
    "browserslist": [
        "> 5%"
    ],
    "dependencies": {
        "@emotion/react": "^11.11.4",
        "@emotion/styled": "^11.11.5",
        "@heroesofcrypto/common": "workspace:*",
        "@mui/base": "^5.0.0-beta.70",
        "@mui/icons-material": "^7.3.5",
        "@mui/joy": "^5.0.0-beta.52",
        "@mui/material": "^7.3.5",
        "@mui/system": "^7.3.5",
        "@rainbow-me/rainbowkit": "^2.2.2",
        "@tanstack/react-query": "^5.62.0",
        "@types/node-schedule": "^2.1.7",
        "@types/randomcolor": "^0.5.9",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@types/react-router-dom": "^5.3.3",
        "@types/uuid": "^11.0.0",
        "axios": "^1.18.0",
        "denque": "^2.1.0",
        "framer-motion": "^12.42.2",
        "gl-matrix": "^3.4.3",
        "os-browserify": "^0.3.0",
        "path-browserify": "^1.0.1",
        "pixi.js": "^8.19.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-is": "^18.3.1",
        "react-router": "^7.18.0",
        "react-router-dom": "^7.18.0",
        "sass": "^1.101.0",
        "sort-package-json": "^3.7.1",
        "typed-glsl": "^0.11.2",
        "typed-signals": "^2.5.0",
        "typeface-open-sans": "1.1.13",
        "uuid": "^11.1.1",
        "viem": "^2.21.53",
        "wagmi": "^2.14.0"
    },
    "devDependencies": {
        "@parcel/config-default": "^2.16.4",
        "@parcel/core": "^2.16.4",
        "@parcel/transformer-sass": "^2.16.4",
        "@vitejs/plugin-react-swc": "^4.3.1",
        "dotenv": "^16.0.0",
        "dotenv-cli": "^7.4.4",
        "parcel": "^2.16.4",
        "rimraf": "^6.1.3",
        "typescript": "^5.9.0",
        "vite": "^8.0.16"
    },
    "alias": {
        "path": "path-browserify",
        "os": "os-browserify"
    }
}
