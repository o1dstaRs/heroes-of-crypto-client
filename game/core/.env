###################################
# .env (dev)
###################################
# Server-side (Node/Bun/Parcel) – keep if you still use them:
PROD=0
HOST_AUTH_API=http://localhost:3001
HOST_MATCHMAKING_API=http://localhost:3001
HOST_GAME_API=http://localhost:3001
PICK_EVENT_SOURCE=http://localhost:3001/v1/game/pick-events

# Client-side (Vite) – add these:
VITE_HOST_AUTH_API=http://localhost:3001
VITE_HOST_MATCHMAKING_API=http://localhost:3001
VITE_HOST_GAME_API=http://localhost:3001
VITE_PICK_EVENT_SOURCE=http://localhost:3001/v1/game/pick-events
# optional override; otherwise use import.meta.env.PROD
VITE_IS_PROD=false
