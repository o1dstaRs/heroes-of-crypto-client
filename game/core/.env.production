# Client-side (Vite) – add these:
VITE_HOST_AUTH_API=https://auth.heroesofcrypto.io
VITE_HOST_MATCHMAKING_API=https://mm.heroesofcrypto.io
VITE_HOST_GAME_API=https://game.heroesofcrypto.io
