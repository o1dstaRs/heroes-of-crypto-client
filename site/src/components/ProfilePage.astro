---
import { content, links, type Language } from "../lib/site-data";

interface Props {
    lang: Language;
}

const { lang } = Astro.props;
const copy = content[lang].profile;
const isRu = lang === "ru";
const profilePath = isRu ? "/ru/profile/" : "/profile/";
const loginHref = `${isRu ? "/ru" : ""}/auth/login/?redirect=${encodeURIComponent(profilePath)}`;
// The ranked redirect page (/play/ranked) forwards into the game app; reuse it for the "play" CTAs.
const rankedApp = links.rankedApp;
---

<section class="profile-page">
    <div class="page-shell profile-shell">
        <header class="profile-head">
            <p class="eyebrow">{copy.title}</p>
            <h1 class="profile-name" data-profile-name>{copy.title}</h1>
            <p class="profile-sub">{copy.subtitle}</p>
            <div class="profile-meta" data-profile-meta hidden>
                <span class="profile-streak" data-profile-streak></span>
                <span class="profile-lastseen" data-profile-lastseen></span>
            </div>
        </header>

        <p class="profile-note" data-profile-loading>{copy.loading}</p>

        <div class="profile-note profile-panel" data-profile-guest hidden>
            <h2>{copy.guestTitle}</h2>
            <p>{copy.guestBody}</p>
            <a class="profile-btn" href={loginHref}>{copy.guestCta}</a>
        </div>

        <div class="profile-note profile-panel" data-profile-error hidden>
            <h2>{copy.errorTitle}</h2>
            <p>{copy.errorBody}</p>
            <button type="button" class="profile-btn" data-profile-retry>{copy.retry}</button>
        </div>

        <div class="profile-content" data-profile-content hidden>
            <div class="profile-panel profile-empty" data-profile-empty hidden>
                <h2>{copy.emptyTitle}</h2>
                <p>{copy.emptyBody}</p>
                <a class="profile-btn" href={rankedApp}>{copy.playCta}</a>
            </div>

            <div class="profile-body" data-profile-sections>
                <section class="profile-section">
                    <h2>{copy.sectionOverview}</h2>
                    <div class="stat-grid" data-profile-stats></div>
                </section>

                <div class="profile-columns">
                    <section class="profile-section">
                        <h2>{copy.sectionFactions}</h2>
                        <div class="bar-list" data-profile-factions></div>
                    </section>
                    <section class="profile-section">
                        <h2>{copy.sectionCreatures}</h2>
                        <div class="bar-list" data-profile-creatures></div>
                    </section>
                </div>

                <section class="profile-section" data-profile-combos-section>
                    <h2>{copy.sectionCombos}</h2>
                    <div class="combo-list" data-profile-combos></div>
                </section>

                <section class="profile-section">
                    <h2>{copy.sectionMatches}</h2>
                    <div class="match-list" data-profile-matches></div>
                </section>
            </div>
        </div>
    </div>

    <script type="application/json" data-profile-copy set:html={JSON.stringify(copy)}></script>
</section>

<script>
    import { isLoggedIn, onAuthStateChange } from "../lib/auth-state";
    import { fetchPlayerPortal, PortalAuthError } from "../lib/portal-client";
    import {
        creatureById,
        factionById,
        streakLabel,
        timeAgo,
        winRateColor,
        winRatePct,
    } from "../lib/portal-data";

    type Copy = Record<string, string>;
    const copyEl = document.querySelector<HTMLElement>("[data-profile-copy]");
    const copy: Copy = copyEl ? JSON.parse(copyEl.textContent || "{}") : {};

    const $ = <T extends HTMLElement = HTMLElement>(name: string): T | null =>
        document.querySelector<T>(`[data-profile-${name}]`);

    const loadingEl = $("loading");
    const guestEl = $("guest");
    const errorEl = $("error");
    const contentEl = $("content");
    const emptyEl = $("empty");
    const sectionsEl = $("sections");
    const nameEl = $("name");
    const metaEl = $("meta");
    const streakEl = $("streak");
    const lastSeenEl = $("lastseen");

    const escapeHtml = (value: string): string =>
        value.replace(
            /[&<>"']/g,
            (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c]!,
        );

    const UNKNOWN_IMG = "/assets/images/units/units/unknown_creature_512.webp";
    const imgFallback = `onerror="this.onerror=null;this.src='${UNKNOWN_IMG}'"`;

    type State = "loading" | "guest" | "error" | "content";
    function showState(state: State): void {
        if (loadingEl) loadingEl.hidden = state !== "loading";
        if (guestEl) guestEl.hidden = state !== "guest";
        if (errorEl) errorEl.hidden = state !== "error";
        if (contentEl) contentEl.hidden = state !== "content";
    }

    const agoLabels = {
        now: copy.agoNow,
        m: copy.agoMinute,
        h: copy.agoHour,
        d: copy.agoDay,
        mo: copy.agoMonth,
        y: copy.agoYear,
    };
    const streakLabels = { win: copy.streakWin, loss: copy.streakLoss, none: copy.streakNone };

    const num = (value: unknown): number => {
        const n = typeof value === "string" ? Number(value) : (value as number);
        return Number.isFinite(n) ? n : 0;
    };

    function statCard(label: string, value: string, accent?: string): string {
        const style = accent ? ` style="color:${accent}"` : "";
        return `<div class="stat-card"><dt>${escapeHtml(label)}</dt><dd${style}>${escapeHtml(value)}</dd></div>`;
    }

    // One "icon · name · win-rate bar · games" row, used for both creatures and factions.
    function barRow(image: string, name: string, wins: number, games: number): string {
        const pct = winRatePct(wins, games);
        const color = winRateColor(pct);
        return `
            <div class="bar-row">
                <img class="bar-icon" src="${image}" alt="" width="34" height="34" loading="lazy" ${imgFallback} />
                <span class="bar-name">${escapeHtml(name)}</span>
                <span class="bar-track"><span class="bar-fill" style="width:${pct}%;background:${color}"></span></span>
                <span class="bar-pct" style="color:${color}">${pct}%</span>
                <span class="bar-games">${games} ${escapeHtml(copy.gamesLabel)}</span>
            </div>`;
    }

    function creatureRow(id: number, wins: number, games: number): string {
        const c = creatureById(id);
        return barRow(c.image, c.name, wins, games);
    }

    function comboRow(creatureIds: number[], wins: number, games: number): string {
        const pct = winRatePct(wins, games);
        const color = winRateColor(pct);
        const icons = creatureIds
            .map((id) => {
                const c = creatureById(id);
                return `<img class="combo-icon" src="${c.image}" alt="${escapeHtml(c.name)}" title="${escapeHtml(
                    c.name,
                )}" width="30" height="30" loading="lazy" ${imgFallback} />`;
            })
            .join("");
        return `
            <div class="combo-row">
                <span class="combo-icons">${icons}</span>
                <span class="combo-games">${games} ${escapeHtml(copy.gamesLabel)}</span>
                <span class="bar-track"><span class="bar-fill" style="width:${pct}%;background:${color}"></span></span>
                <span class="bar-pct" style="color:${color}">${pct}%</span>
            </div>`;
    }

    function matchRow(match: any): string {
        const won = !!match.won;
        const abandoned = !!match.abandoned;
        const resultLabel = abandoned ? copy.resultAbandoned : won ? copy.resultWin : copy.resultLoss;
        const resultClass = won ? "win" : "loss";
        const icons = (match.creature_ids ?? [])
            .map((id: number) => {
                const c = creatureById(id);
                return `<img class="match-icon" src="${c.image}" alt="${escapeHtml(c.name)}" title="${escapeHtml(
                    c.name,
                )}" width="26" height="26" loading="lazy" ${imgFallback} />`;
            })
            .join("");
        const opponent = escapeHtml(match.opponent_username || "—");
        const when = timeAgo(num(match.finished_time), agoLabels);
        return `
            <div class="match-row">
                <span class="match-result ${resultClass}">${escapeHtml(resultLabel)}</span>
                <span class="match-icons">${icons}</span>
                <span class="match-vs">${escapeHtml(copy.versus)} <strong>${opponent}</strong></span>
                <span class="match-when">${escapeHtml(when)}</span>
            </div>`;
    }

    function render(portal: any): void {
        const wins = num(portal.wins);
        const losses = num(portal.losses);
        const games = num(portal.total_games_played);
        const winRate = winRatePct(wins, games);

        if (nameEl) nameEl.textContent = portal.username || copy.title;

        const currentStreak = num(portal.current_streak);
        if (metaEl) metaEl.hidden = false;
        if (streakEl) streakEl.textContent = streakLabel(currentStreak, streakLabels);
        const lastLogin = num(portal.last_login);
        if (lastSeenEl) {
            const ago = timeAgo(lastLogin, agoLabels);
            lastSeenEl.textContent = ago ? `${copy.lastLoginPrefix} ${ago}` : "";
        }

        const matches = (portal.recent_matches ?? []) as any[];
        const creatures = (portal.creature_stats ?? []) as any[];
        const factions = (portal.faction_stats ?? []) as any[];
        const combos = (portal.combos ?? []) as any[];

        const noData = games <= 0 && matches.length === 0 && creatures.length === 0;
        if (emptyEl) emptyEl.hidden = !noData;
        if (sectionsEl) sectionsEl.hidden = noData;

        const statsEl = $("stats");
        if (statsEl) {
            statsEl.innerHTML = [
                statCard(copy.statWins, String(wins), "#46d160"),
                statCard(copy.statLosses, String(losses), "#ff5a5a"),
                statCard(copy.statWinRate, `${winRate}%`, winRateColor(winRate)),
                statCard(copy.statGames, String(games)),
                statCard(copy.statCurrentStreak, streakLabel(currentStreak, streakLabels)),
                statCard(copy.statBestStreak, streakLabel(num(portal.best_win_streak), streakLabels)),
            ].join("");
        }

        const factionsEl = $("factions");
        if (factionsEl) {
            factionsEl.innerHTML = factions
                .slice()
                .sort((a, b) => num(b.games) - num(a.games))
                .map((f) => {
                    const info = factionById(num(f.faction));
                    return barRow(info.image, info.name, num(f.wins), num(f.games));
                })
                .join("");
        }

        const creaturesEl = $("creatures");
        if (creaturesEl) {
            creaturesEl.innerHTML = creatures
                .slice()
                .sort((a, b) => num(b.games) - num(a.games))
                .slice(0, 14)
                .map((c) => creatureRow(num(c.creature_id), num(c.wins), num(c.games)))
                .join("");
        }

        const combosEl = $("combos");
        const combosSection = $("combos-section");
        if (combosEl) {
            combosEl.innerHTML = combos
                .map((c) => comboRow((c.creature_ids ?? []).map(num), num(c.wins), num(c.games)))
                .join("");
            if (combosSection) combosSection.hidden = combos.length === 0;
        }

        const matchesEl = $("matches");
        if (matchesEl) {
            matchesEl.innerHTML = matches.map((m) => matchRow(m)).join("");
        }

        showState("content");
    }

    async function load(): Promise<void> {
        if (!isLoggedIn()) {
            showState("guest");
            return;
        }
        showState("loading");
        try {
            render(await fetchPlayerPortal());
        } catch (error) {
            showState(error instanceof PortalAuthError ? "guest" : "error");
        }
    }

    $("retry")?.addEventListener("click", () => void load());
    // React to login/logout happening in another tab or via the header while this page is open.
    onAuthStateChange(() => void load());
</script>

<style>
    .profile-page {
        min-height: calc(100svh - 68px);
        background: linear-gradient(180deg, #070808, #050606);
    }

    .profile-shell {
        padding: 56px 0 80px;
    }

    .profile-head {
        margin-bottom: 30px;
    }

    .profile-name {
        margin: 6px 0 8px;
        color: #fff;
        font-size: clamp(1.8rem, 3vw, 2.6rem);
        line-height: 1.05;
    }

    .profile-sub {
        max-width: 620px;
        color: rgba(251, 244, 232, 0.72);
    }

    .profile-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 10px 16px;
        align-items: center;
        margin-top: 14px;
    }

    .profile-meta[hidden] {
        display: none;
    }

    .profile-streak {
        padding: 5px 12px;
        border: 1px solid rgba(242, 199, 93, 0.32);
        border-radius: 999px;
        background: rgba(242, 199, 93, 0.1);
        color: var(--gold, #f2c75d);
        font-size: 0.82rem;
        font-weight: 750;
    }

    .profile-lastseen {
        color: rgba(251, 244, 232, 0.5);
        font-size: 0.82rem;
    }

    .profile-note {
        color: rgba(251, 244, 232, 0.68);
    }

    .profile-note[hidden],
    .profile-content[hidden],
    .profile-empty[hidden],
    .profile-body[hidden],
    [data-profile-combos-section][hidden] {
        display: none;
    }

    .profile-panel {
        display: grid;
        gap: 10px;
        justify-items: start;
        max-width: 560px;
        margin-top: 16px;
        padding: 24px 26px;
        border: 1px solid var(--line, rgba(255, 255, 255, 0.16));
        border-radius: 12px;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.025));
    }

    .profile-panel h2 {
        margin: 0;
        color: #fff;
        font-size: 1.3rem;
    }

    .profile-panel p {
        margin: 0;
        color: rgba(251, 244, 232, 0.72);
    }

    .profile-btn {
        margin-top: 6px;
        padding: 9px 18px;
        border: 1px solid rgba(242, 199, 93, 0.5);
        border-radius: 8px;
        background: rgba(242, 199, 93, 0.12);
        color: var(--gold, #f2c75d);
        font-weight: 750;
        font-size: 0.9rem;
        cursor: pointer;
        transition:
            border-color 0.18s ease,
            background 0.18s ease;
    }

    .profile-btn:hover {
        border-color: rgba(242, 199, 93, 0.8);
        background: rgba(242, 199, 93, 0.2);
    }

    .profile-body {
        display: grid;
        gap: 30px;
    }

    .profile-section h2 {
        margin: 0 0 14px;
        color: #fff;
        font-size: 1.24rem;
    }

    .profile-columns {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 30px;
    }

    .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 12px;
    }

    .stat-card {
        display: grid;
        gap: 4px;
        padding: 16px 18px;
        border: 1px solid var(--line, rgba(255, 255, 255, 0.14));
        border-radius: 10px;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.03));
    }

    .stat-card dt {
        color: rgba(251, 244, 232, 0.58);
        font-size: 0.74rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .stat-card dd {
        margin: 0;
        color: #fff;
        font-size: 1.5rem;
        font-weight: 820;
    }

    .bar-list,
    .combo-list,
    .match-list {
        display: grid;
        gap: 8px;
    }

    .bar-row {
        display: grid;
        grid-template-columns: 34px minmax(0, 1fr) minmax(80px, 160px) 42px auto;
        gap: 10px;
        align-items: center;
        padding: 8px 12px;
        border: 1px solid var(--line, rgba(255, 255, 255, 0.1));
        border-radius: 9px;
        background: rgba(255, 255, 255, 0.03);
    }

    .bar-icon,
    .combo-icon,
    .match-icon {
        border-radius: 22%;
        background: rgba(0, 0, 0, 0.35);
        border: 1px solid rgba(242, 199, 93, 0.28);
        object-fit: cover;
    }

    .bar-name {
        overflow: hidden;
        color: rgba(251, 244, 232, 0.9);
        font-weight: 650;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .bar-track {
        position: relative;
        height: 8px;
        border-radius: 4px;
        background: rgba(255, 255, 255, 0.08);
        overflow: hidden;
    }

    .bar-fill {
        position: absolute;
        inset: 0;
        border-radius: 4px;
    }

    .bar-pct {
        font-size: 0.84rem;
        font-weight: 700;
        text-align: right;
    }

    .bar-games {
        color: rgba(251, 244, 232, 0.5);
        font-size: 0.8rem;
        white-space: nowrap;
    }

    .combo-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto minmax(80px, 160px) 42px;
        gap: 12px;
        align-items: center;
        padding: 8px 12px;
        border: 1px solid var(--line, rgba(255, 255, 255, 0.1));
        border-radius: 9px;
        background: rgba(255, 255, 255, 0.03);
    }

    .combo-icons,
    .match-icons {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
    }

    .combo-games {
        color: rgba(251, 244, 232, 0.5);
        font-size: 0.8rem;
        white-space: nowrap;
    }

    .match-row {
        display: grid;
        grid-template-columns: 74px minmax(0, auto) minmax(0, 1fr) auto;
        gap: 12px;
        align-items: center;
        padding: 8px 12px;
        border: 1px solid var(--line, rgba(255, 255, 255, 0.1));
        border-radius: 9px;
        background: rgba(255, 255, 255, 0.03);
    }

    .match-result {
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 0.76rem;
        font-weight: 800;
        text-align: center;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .match-result.win {
        background: rgba(70, 209, 96, 0.16);
        color: #46d160;
    }

    .match-result.loss {
        background: rgba(255, 90, 90, 0.16);
        color: #ff5a5a;
    }

    .match-vs {
        overflow: hidden;
        color: rgba(251, 244, 232, 0.66);
        font-size: 0.9rem;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .match-vs strong {
        color: rgba(251, 244, 232, 0.92);
    }

    .match-when {
        color: rgba(251, 244, 232, 0.46);
        font-size: 0.82rem;
        white-space: nowrap;
    }

    @media (max-width: 820px) {
        .profile-columns {
            grid-template-columns: 1fr;
            gap: 28px;
        }
    }

    @media (max-width: 560px) {
        .bar-row {
            grid-template-columns: 30px minmax(0, 1fr) 40px;
            row-gap: 6px;
        }

        .bar-track {
            grid-column: 1 / -1;
            order: 3;
        }

        .bar-games {
            display: none;
        }

        .match-row {
            grid-template-columns: 66px minmax(0, 1fr);
        }

        .match-icons {
            grid-column: 1 / -1;
        }

        .match-when {
            display: none;
        }
    }
</style>
