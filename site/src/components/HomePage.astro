---
import { content, contractAddress, links, localPath, type Language } from "../lib/site-data";
import { localizedFactionName } from "../lib/localization";
import { abilityCount, factionColors, factionUnits, unitCount, type Unit } from "../lib/units-data";
import AnimatedUnit from "./AnimatedUnit.astro";

// Frameless animated sprite-sheets (8x10, 73 frames) exported from the game for the hero spotlight.
const animAtlas: Record<string, string> = {
    "Black Dragon": "/assets/images/units/anim/black_dragon_default_atlas_half.webp",
    Angel: "/assets/images/units/anim/angel_default_atlas_half.webp",
    Behemoth: "/assets/images/units/anim/behemoth_default_atlas_half.webp",
    Thunderbird: "/assets/images/units/anim/thunderbird_default_atlas_half.webp",
};

interface Props {
    lang: Language;
}

const { lang } = Astro.props;
const copy = content[lang];
const homeLabels =
    lang === "ru"
        ? {
              rosterEyebrow: "Живой ростер",
              rosterCta: "Все юниты",
              factionRail: "Выберите фракцию",
              units: "юнитов",
              level: "Ур.",
              featured: "Готовы к бою",
              gameStats: "Статистика игры",
              arenaImage: "Сцена боя Heroes of Crypto",
          }
        : {
              rosterEyebrow: "Live roster",
              rosterCta: "All units",
              factionRail: "Choose a faction",
              units: "units",
              level: "Lv.",
              featured: "Ready to deploy",
              gameStats: "Game stats",
              arenaImage: "Heroes of Crypto livestream battle scene",
          };
const heroStats = [
    { value: String(factionUnits.length), label: copy.hero.stats[0]?.label ?? "Factions" },
    { value: String(unitCount), label: copy.hero.stats[1]?.label ?? "Combat units" },
    { value: String(abilityCount), label: copy.hero.stats[2]?.label ?? "Abilities" },
];
const allUnits = factionUnits.flatMap((faction) => faction.units);
const findUnit = (name: string) => allUnits.find((unit) => unit.name === name);
const fallbackHeroUnits = factionUnits.map((faction) => faction.units[faction.units.length - 1]).filter(Boolean);
const heroUnits = [
    findUnit("Black Dragon"),
    findUnit("Angel"),
    findUnit("Behemoth"),
    findUnit("Thunderbird"),
].filter(Boolean) as Unit[];
const spotlightUnits = heroUnits.length === 4 ? heroUnits : fallbackHeroUnits;
const factionHighlights = factionUnits.map((faction) => ({
    ...faction,
    featuredUnits: [...faction.units].sort((a, b) => b.level - a.level || a.name.localeCompare(b.name)).slice(0, 4),
    unitCount: faction.units.length,
}));
const featureVisuals = [
    {
        variant: "board",
        icons: [
            "/assets/images/units/abilities/movement_augment_256.webp",
            "/assets/images/units/abilities/through_shot_256.webp",
            "/assets/images/units/abilities/tie_up_the_horses_aura_256.webp",
        ],
    },
    {
        variant: "factions",
        units: factionHighlights.map((faction) => faction.featuredUnits[0]).filter(Boolean),
    },
    {
        variant: "abilities",
        icons: [
            "/assets/images/units/abilities/chain_lightning_256.webp",
            "/assets/images/units/abilities/resurrection_256.webp",
            "/assets/images/units/abilities/fire_breath_256.webp",
            "/assets/images/units/abilities/mass_magic_mirror_256.webp",
        ],
    },
] as const;
const featureCards = copy.features.items.map((item, index) => ({
    ...item,
    visual: featureVisuals[index] ?? featureVisuals[0],
}));
const unitsHref = localPath(lang, "units");
const rulesHref = localPath(lang, "rules");
const playHref = lang === "ru" ? "/ru/play/" : links.play;
const factionUnitsHref = (faction: string) => `${unitsHref}?faction=${encodeURIComponent(faction.toLowerCase())}`;
const factionLabel = (faction: string) => localizedFactionName(lang, faction);
---

<section class="hero">
    <img
        class="hero-bg"
        src="/assets/images/background_dark_old.webp"
        alt=""
        width="1024"
        height="1024"
        fetchpriority="high"
    />
    <div class="hero-shade"></div>
    <div class="hero-grid page-shell">
        <div class="hero-content">
            <p class="eyebrow">{copy.hero.kicker}</p>
            <h1 class="hero-logo">
                <img
                    src="/assets/images/home/logo/logo_transparent.webp"
                    alt={copy.hero.title}
                    width="640"
                    height="200"
                    fetchpriority="high"
                />
                <span class="sr-only">{copy.hero.title}</span>
            </h1>
            <p class="hero-tagline">{copy.hero.tagline}</p>
            <p class="hero-copy">{copy.hero.body}</p>
            <div class="hero-actions">
                <a class="button primary hero-play" href={playHref}>
                    <img src="/assets/icons/navbar/joystick.svg" alt="" width="22" height="22" />
                    {copy.hero.primaryCta}
                </a>
                <a class="button secondary" href={rulesHref}>
                    {copy.hero.secondaryCta}
                </a>
            </div>
        </div>

        <div class="hero-roster-stage" aria-label={homeLabels.rosterEyebrow}>
            <div class="hero-roster-heading">
                <span>{homeLabels.rosterEyebrow}</span>
                <a href={unitsHref}>{homeLabels.rosterCta}</a>
            </div>
            <div class="hero-unit-battleline">
                {
                    spotlightUnits.map((unit, index) => {
                        // TEST: first two units render frameless + animated (sprite-sheet), the last two
                        // keep the framed portrait chip — so we can compare and pick a direction.
                        const atlas = animAtlas[unit.name];
                        if (index < 2 && atlas) {
                            return (
                                <a
                                    class="hero-unit-anim"
                                    href={factionUnitsHref(unit.faction)}
                                    style={`--faction: ${factionColors[unit.faction]}`}
                                    aria-label={`${unit.name}, ${factionLabel(unit.faction)}`}
                                >
                                    <span class="hero-unit-anim-stage">
                                        <AnimatedUnit atlas={atlas} label={unit.name} />
                                    </span>
                                    <span class="hero-unit-text">
                                        <strong>{unit.name}</strong>
                                        <span>{factionLabel(unit.faction)}</span>
                                    </span>
                                    <em>{homeLabels.level} {unit.level}</em>
                                </a>
                            );
                        }
                        return (
                            <a
                                class="hero-unit-chip"
                                href={factionUnitsHref(unit.faction)}
                                style={`--faction: ${factionColors[unit.faction]}`}
                                aria-label={`${unit.name}, ${factionLabel(unit.faction)}`}
                            >
                                <span class="hero-unit-image">
                                    <img src={unit.portrait} alt="" width="512" height="512" />
                                </span>
                                <span class="hero-unit-text">
                                    <strong>{unit.name}</strong>
                                    <span>{factionLabel(unit.faction)}</span>
                                </span>
                                <em>{homeLabels.level} {unit.level}</em>
                            </a>
                        );
                    })
                }
            </div>
            <div class="hero-roster-caption">
                <span>{homeLabels.featured}</span>
            </div>
        </div>
    </div>
</section>

<section class="proof-strip" aria-label={homeLabels.gameStats}>
    <div class="page-shell proof-grid">
        {
            heroStats.map((stat) => (
                <div class="proof-item">
                    <strong>{stat.value}</strong>
                    <span>{stat.label}</span>
                </div>
            ))
        }
        <a class="proof-action proof-action-primary" href={playHref}>{copy.progress.cta}</a>
    </div>
</section>

<section class="faction-rail-section" aria-label={homeLabels.factionRail}>
    <div class="page-shell faction-rail">
        {
            factionHighlights.map((faction) => (
                <a class="faction-quick" href={factionUnitsHref(faction.faction)} style={`--faction: ${faction.color}`}>
                    <span class="faction-quick-head">
                        <img src={faction.icon} alt="" width="34" height="34" loading="lazy" />
                        <span>
                            <strong>{factionLabel(faction.faction)}</strong>
                            <em>{faction.unitCount} {homeLabels.units}</em>
                        </span>
                    </span>
                    <span class="faction-mini-units">
                        {faction.featuredUnits.slice(0, 3).map((unit) => (
                            <img src={unit.icon} alt="" width="72" height="72" loading="lazy" />
                        ))}
                    </span>
                </a>
            ))
        }
    </div>
</section>

<section class="section arena-section">
    <div class="page-shell arena-layout">
        <div class="arena-copy">
            <p class="eyebrow">{copy.progress.eyebrow}</p>
            <h2>{copy.progress.title}</h2>
            <p>{copy.progress.body}</p>
            <div class="arena-actions">
                <a class="button primary" href={playHref}>
                    <img src="/assets/icons/navbar/joystick.svg" alt="" width="21" height="21" />
                    {copy.progress.cta}
                </a>
            </div>
        </div>
        <div class="arena-media">
            <img src="/assets/images/home/livestream.webp" alt={homeLabels.arenaImage} loading="lazy" width="1792" height="1024" />
        </div>
    </div>
</section>

<section class="section roster-section">
    <div class="page-shell split">
        <div class="home-roster-board" aria-label={copy.roster.title}>
            {
                factionHighlights.map((faction) => (
                    <article class="home-faction-panel" style={`--faction: ${faction.color}`}>
                        <div class="home-faction-title">
                            <img src={faction.icon} alt="" width="28" height="28" loading="lazy" />
                            <strong>{factionLabel(faction.faction)}</strong>
                        </div>
                        <div class="home-unit-grid">
                            {faction.featuredUnits.map((unit) => (
                                <a class="home-unit-tile" href={factionUnitsHref(faction.faction)}>
                                    <img src={unit.icon} alt="" width="512" height="512" loading="lazy" />
                                    <span>{unit.name}</span>
                                </a>
                            ))}
                        </div>
                    </article>
                ))
            }
        </div>
        <div class="section-copy">
            <p class="eyebrow">{copy.roster.eyebrow}</p>
            <h2>{copy.roster.title}</h2>
            <p>{copy.roster.body}</p>
            <div class="pill-list">
                {copy.roster.points.map((point) => <span>{point}</span>)}
            </div>
        </div>
    </div>
</section>

<section class="section feature-section" id="features">
    <div class="page-shell">
        <div class="section-heading centered">
            <p class="eyebrow">{copy.features.eyebrow}</p>
            <h2>{copy.features.title}</h2>
        </div>
        <div class="feature-grid mechanic-grid">
            {
                featureCards.map((item) => (
                    <article class={`feature-card mechanic-card is-${item.visual.variant}`}>
                        <div class="mechanic-visual" aria-hidden="true">
                            {
                                item.visual.variant === "board" && (
                                    <div class="mechanic-board">
                                        <img
                                            src="/assets/images/preview_game.webp"
                                            alt=""
                                            width="1200"
                                            height="630"
                                            loading="lazy"
                                        />
                                        <span class="board-path one"></span>
                                        <span class="board-path two"></span>
                                        <span class="board-marker one"></span>
                                        <span class="board-marker two"></span>
                                        <span class="board-marker three"></span>
                                        <span class="mechanic-icon-row">
                                            {item.visual.icons.map((icon) => (
                                                <img src={icon} alt="" width="256" height="256" loading="lazy" />
                                            ))}
                                        </span>
                                    </div>
                                )
                            }
                            {
                                item.visual.variant === "factions" && (
                                    <div class="mechanic-factions">
                                        {item.visual.units.map((unit) => (
                                            <span class="mechanic-faction-unit" style={`--faction: ${factionColors[unit.faction]}`}>
                                                <img src={unit.icon} alt="" width="512" height="512" loading="lazy" />
                                                <em>{factionLabel(unit.faction)}</em>
                                            </span>
                                        ))}
                                    </div>
                                )
                            }
                            {
                                item.visual.variant === "abilities" && (
                                    <div class="mechanic-abilities">
                                        {item.visual.icons.map((icon) => (
                                            <span>
                                                <img src={icon} alt="" width="256" height="256" loading="lazy" />
                                            </span>
                                        ))}
                                    </div>
                                )
                            }
                        </div>
                        <div class="mechanic-copy">
                            <h3>{item.title}</h3>
                            <p>{item.description}</p>
                        </div>
                    </article>
                ))
            }
        </div>
    </div>
</section>

<section class="section token-preview">
    <div class="page-shell">
        <div class="section-heading">
            <p class="eyebrow">{copy.token.eyebrow}</p>
            <h2>{copy.token.title}</h2>
            <p>{copy.token.body}</p>
        </div>

        <div class="token-layout">
            <div class="contract-box">
                <span>{copy.token.contractLabel}</span>
                <code>{contractAddress}</code>
                <div class="token-links compact">
                    {copy.token.links.map((link) => <a href={link.href} target="_blank" rel="noopener">{link.label}</a>)}
                </div>
            </div>
            <div class="allocation-list">
                {
                    copy.token.allocation.map((item) => (
                        <article class="allocation-item" style={`--bar-value: ${item.value}%`}>
                            <div class="allocation-title">
                                <h3>{item.label}</h3>
                                <strong>{item.value}%</strong>
                            </div>
                            <div class="allocation-bar" aria-hidden="true"><span></span></div>
                            <p>{item.description}</p>
                        </article>
                    ))
                }
            </div>
        </div>
    </div>
</section>

<section class="final-cta">
    <div class="page-shell final-cta-inner">
        <div>
            <p class="eyebrow">{copy.hero.kicker}</p>
            <h2>{copy.hero.tagline}</h2>
        </div>
        <div class="final-cta-actions">
            <a class="button primary" href={playHref}>
                <img src="/assets/icons/navbar/joystick.svg" alt="" width="22" height="22" />
                {copy.hero.primaryCta}
            </a>
            <a class="button secondary" href={rulesHref}>
                {copy.hero.secondaryCta}
            </a>
        </div>
    </div>
</section>

<section class="section roadmap-section">
    <div class="page-shell">
        <div class="section-heading centered">
            <p class="eyebrow">{copy.roadmap.eyebrow}</p>
            <h2>{copy.roadmap.title}</h2>
        </div>
        <div class="roadmap-grid">
            {
                copy.roadmap.items.map((item) => (
                    <article class="roadmap-item">
                        <time>{item.time}</time>
                        <h3>{item.title}</h3>
                        <p>{item.description}</p>
                    </article>
                ))
            }
        </div>
    </div>
</section>
