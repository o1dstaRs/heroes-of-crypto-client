              { label: "Здоровье", text: "сколько здоровья у одного существа внутри стека" },
              { label: "Урон", text: "базовый разброс удара до брони, удачи и модификаторов" },
              { label: "Скорость", text: "сильно влияет на порядок ходов внутри круга" },
              { label: "Шаги", text: "сколько клеток юнит может пройти за ход" },
