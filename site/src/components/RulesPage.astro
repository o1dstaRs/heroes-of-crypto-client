---
import { links, localPath, type Language } from "../lib/site-data";
import { localizedFactionName } from "../lib/localization";
import { abilityCount, factionColors, factionUnits, unitCount, type FactionName, type Unit } from "../lib/units-data";

interface Props {
    lang: Language;
}

const { lang } = Astro.props;
const isRu = lang === "ru";
const allUnits = factionUnits.flatMap((faction) => faction.units);
const byName = new Map(allUnits.map((unit) => [unit.name, unit]));
const pickUnits = (names: string[]) => names.map((name) => byName.get(name)).filter(Boolean) as Unit[];
const heroUnits = pickUnits(["Black Dragon", "Angel", "Behemoth", "Pegasus"]);
const exampleUnits = pickUnits(["Medusa", "Arbalester", "Hydra", "Thunderbird", "Satyr", "Gargantuan"]);
const unitsHref = localPath(lang, "units");
const playHref = isRu ? "/ru/play/" : links.play;
const factionLabel = (faction: string) => localizedFactionName(lang, faction);

const attackLabels = isRu
    ? {
          MELEE: "Ближний бой",
          RANGE: "Стрельба",
          MAGIC: "Магия",
          MELEE_MAGIC: "Ближний бой / магия",
      }
    : {
          MELEE: "Melee",
          RANGE: "Ranged",
          MAGIC: "Magic",
          MELEE_MAGIC: "Melee / magic",
      };

const movementLabels = isRu
    ? { WALK: "Пеший", FLY: "Летающий", TELEPORT: "Телепорт" }
    : { WALK: "Walk", FLY: "Fly", TELEPORT: "Teleport" };

const roleCounts = allUnits.reduce<Record<string, number>>((counts, unit) => {
    counts[unit.attackType] = (counts[unit.attackType] ?? 0) + 1;
    return counts;
}, {});

const levelCounts = allUnits.reduce<Record<number, number>>((counts, unit) => {
    counts[unit.level] = (counts[unit.level] ?? 0) + 1;
    return counts;
}, {});
const levelRows = [1, 2, 3, 4].map((level) => ({
    level,
    draft: [2, 2, 1, 1][level - 1],
    available: levelCounts[level] ?? 0,
}));

// Quick-reference numbers, all taken from the shared engine constants (constants.ts / grid).
// Each carries a short "what it means / how it affects the fight" tip shown on hover/focus.
const quickFacts = [
    {
        value: "16 × 16",
        label: isRu ? "клеток на поле" : "battlefield cells",
        tip: isRu
            ? "Поле боя — сетка 16×16. В этих клетках измеряются ходы, дальность атак и радиусы аур."
            : "The battlefield is a 16×16 grid. Every move, attack range and aura radius is measured in these cells.",
    },
    {
        value: "8",
        label: isRu ? "макс. стеков в армии" : "max stacks per army",
        tip: isRu
            ? "На поле помещается максимум 8 стеков (отрядов). Больше стеков — больше действий за круг и контроль доски."
            : "You can field at most 8 stacks (unit groups). More stacks means more actions per lap and board control.",
    },
    {
        value: "2 / 2 / 1 / 1",
        label: isRu ? "драфт по уровням 1–4" : "draft by level 1–4",
        tip: isRu
            ? "За матч вы берёте 2 юнита 1 уровня, 2 — 2-го, 1 — 3-го и 1 — 4-го. Старшие уровни сильнее, но их всего по одному."
            : "Each match you draft two level-1 units, two level-2, one level-3 and one level-4. Higher levels are stronger, but you get only one each.",
    },
    {
        value: "7",
        label: isRu ? "очков апгрейдов" : "augment points",
        tip: isRu
            ? "До боя вы тратите 7 очков на командные апгрейды (броня, ближний бой, стрельба, движение, зона расстановки) — реальные компромиссы."
            : "Before the fight you spend 7 points on team augments (armor, melee, ranged, movement, deployment) — real trade-offs, not cosmetics.",
    },
    {
        value: "−20 … +20",
        label: isRu ? "диапазон морали" : "morale range",
        tip: isRu
            ? "Мораль задаёт темп: при высокой юнит может сходить лишний раз (и чуть сильнее), при низкой — пропустить ход. Растёт от наступления и убийств, падает от отхода и потерь."
            : "Morale drives tempo: high morale can grant an extra turn (and a small boost); low morale can make a unit skip. Built by advancing and killing, lost by retreating and losing stacks.",
    },
    {
        value: "−10 … +10",
        label: isRu ? "диапазон удачи" : "luck range",
        tip: isRu
            ? "Удача — в основном защита: удачливый стек получает меньше урона (~1% за очко), неудачливый — больше. Ещё усиливает способности. Каждый круг сдвигается на ±3."
            : "Luck is mostly defensive: a lucky stack takes less damage (~1% per point), an unlucky one takes more. It also powers your abilities, and drifts by up to ±3 each lap.",
    },
    {
        value: "1 – 5",
        label: isRu ? "сила стека" : "stack power",
        tip: isRu
            ? "Оценка 1–5 ценности стека на доске (ценность юнита × число живых, относительно крупнейшего стека). Чем выше, тем сильнее его способности."
            : "A 1–5 rating of how valuable a stack is (unit value × living count vs the biggest stack). Higher stack power scales its abilities.",
    },
    {
        value: isRu ? "кажд. 3–4 круга" : "every 3–4 laps",
        label: isRu ? "сужение карты" : "map narrowing",
        tip: isRu
            ? "Карта сужается каждые 3 круга (4 на картах с заблокированным центром): крайние клетки становятся провалами. Юнитов толкает внутрь, а без места — убивает."
            : "The map shrinks every 3 laps (4 on block-center maps): outer cells turn into holes. Units are pushed inward — or die if there's no room. Don't get caught on the edge.",
    },
    {
        value: isRu ? "круг 12 · 4" : "lap 12 · 4",
        label: isRu ? "Армагеддон, волн" : "Armageddon, waves",
        tip: isRu
            ? "Если бой тянется до 12-го круга, начинается Армагеддон: 4 нарастающие волны урона по всем, пока кто-то не победит. Затягивать бесконечно нельзя."
            : "If the fight drags to lap 12, Armageddon begins: 4 escalating damage waves hit everything until someone wins. Fights can't stall forever.",
    },
    {
        value: isRu ? "12–60 сек" : "12–60 s",
        label: isRu ? "время на ход" : "per-turn timer",
        tip: isRu
            ? "На ход даётся 12–60 секунд (в рамках общего бюджета ~4 минуты). Не успели — ход пропускается, и юнит теряет мораль."
            : "Each turn gives 12–60 seconds to act (within a ~4-minute total budget). Run out and the turn is skipped — and the unit loses morale.",
    },
    {
        value: "×8",
        label: isRu ? "макс. штраф дальности" : "max range divisor",
        tip: isRu
            ? "Стрельба дальше дистанции выстрела делит урон — вплоть до ×8 на больших расстояниях. Держите стрелков в радиусе или берите апгрейд Стрельба, чтобы снять штраф."
            : "Shooting past a unit's range distance divides its damage — up to ×8 at long range. Keep shooters in range, or take the Sniper augment to ignore it.",
    },
    {
        value: "×0.5",
        label: isRu ? "стрелок в упор" : "ranged-in-melee",
        tip: isRu
            ? "Стрелок, вынужденный бить в ближнем бою, наносит половину урона (если нет способности на ближний бой). Не подпускайте врага вплотную к стрелкам."
            : "A ranged unit forced to fight in melee deals half damage (unless an ability covers melee). Keep shooters out of melee contact.",
    },
];

// Augment tiers, verified from augments/augment_properties.ts.
const augmentTable = [
    {
        icon: "/assets/images/units/abilities/armor_augment_256.webp",
        name: isRu ? "Броня" : "Armor",
        tiers: ["+6%", "+13%", "+21%"],
        note: isRu ? "броня команды" : "team armor",
    },
    {
        icon: "/assets/images/units/abilities/might_augment_256.webp",
        name: isRu ? "Сила" : "Might",
        tiers: ["+8%", "+17%", "+27%"],
        note: isRu ? "ближняя атака" : "melee attack",
    },
    {
        icon: "/assets/images/units/abilities/sniper_augment_256.webp",
        name: isRu ? "Стрельба" : "Sniper",
        tiers: ["+7%", "+15%", "+24%"],
        note: isRu ? "атака + дистанция, без штрафа" : "attack + range, ignores divisor",
    },
    {
        icon: "/assets/images/units/abilities/movement_augment_256.webp",
        name: isRu ? "Движение" : "Movement",
        tiers: ["+1", "+2", "—"],
        note: isRu ? "шага к ходу" : "steps to move",
    },
    {
        icon: "/assets/images/units/abilities/board_augment_256.webp",
        name: isRu ? "Расстановка" : "Placement",
        tiers: isRu ? ["3 ряда", "4 ряда", "5 рядов"] : ["3 rows", "4 rows", "5 rows"],
        note: isRu ? "зона расстановки, шире" : "deployment zone, wider",
    },
];

const copy = isRu
