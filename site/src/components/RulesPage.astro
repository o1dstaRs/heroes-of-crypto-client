          synergyLevels: "Уровни силы",
          synergies: [
              {
                  faction: "Life",
                  icon: "/assets/images/units/factions/life_128.webp",
                  options: ["Снабжение: +6% / +12% / +19% существ в стеках", "Мораль и удача: +6/+2, +13/+5, +20/+9"],
              },
              {
                  faction: "Chaos",
                  icon: "/assets/images/units/factions/chaos_128.webp",
                  options: ["Движение: +1 / +2 / +3 клетки", "Срыв при атаке: 8% / 13% / 19% шанс выключить способности"],
              },
              {
                  faction: "Might",
                  icon: "/assets/images/units/factions/might_128.webp",
                  options: ["Радиус аур: +1 / +2 / +3 клетки", "Сила способностей от стека: +5% / +8% / +12%"],
              },
              {
                  faction: "Nature",
                  icon: "/assets/images/units/factions/nature_128.webp",
                  options: ["Юниты на поле: +1 / +2 / +3 выставленных стека", "Броня летающих юнитов: +10% / +20% / +30%"],
              },
          ],
          placementTitle: "Расстановка: бой часто выигрывается до первого удара",
          placementParagraphs: [
              "Вы выбираете юнита из списка, задаете количество существ в стеке и ставите его в разрешенную зону. Можно двигать уже поставленные стеки, клонировать выбранный стек, удалять его и подгонять финальную формацию перед стартом.",
