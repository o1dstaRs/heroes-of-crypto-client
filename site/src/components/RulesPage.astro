              },
              {
                  icon: "/assets/images/units/abilities/armor_augment_256.webp",
                  title: "Броня",
                  text: "+6%, +13% или +21% к броне команды. Хорошо работает с армиями, которые хотят пережить первый контакт.",
              },
              {
                  icon: "/assets/images/units/abilities/might_augment_256.webp",
                  title: "Ближний бой",
                  text: "+8%, +17% или +27% к ближней атаке. Это выбор для армий, которые готовы драться лицом к лицу.",
