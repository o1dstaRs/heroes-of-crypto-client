---
import { content, type Language } from "../lib/site-data";
import { localizedFactionName } from "../lib/localization";
import { abilities, abilitiesCount, factionColors } from "../lib/units-data";

interface Props {
    lang: Language;
}

const { lang } = Astro.props;
const copy = content[lang];
const page = copy.pages.abilities;
const unitsHref = lang === "ru" ? "/ru/units/" : "/units/";

const labels =
    lang === "ru"
        ? {
              eyebrow: "Справочник способностей",
              search: "Поиск способностей",
              searchPlaceholder: "Название, описание, юнит...",
              empty: "Способности не найдены.",
              usedBy: "Носители",
              all: "Все",
              passive: "Пассивные",
              aura: "Аура",
              active: "Активные",
              abilities: "Способностей",
              auras: "Аур",
              actives: "Активных",
              filter: "Фильтр по типу",
          }
        : {
              eyebrow: "Ability codex",
              search: "Search abilities",
              searchPlaceholder: "Name, description, unit...",
              empty: "No abilities found.",
              usedBy: "Used by",
              all: "All",
              passive: "Passive",
              aura: "Aura",
              active: "Active",
              abilities: "Abilities",
              auras: "Auras",
              actives: "Active",
              filter: "Filter by type",
          };

const kindLabel = (kind: string) =>
    kind === "aura" ? labels.aura : kind === "active" ? labels.active : labels.passive;

const auraCount = abilities.filter((a) => a.kind === "aura").length;
const activeCount = abilities.filter((a) => a.kind === "active").length;

const summaryStats = [
    { value: abilitiesCount, label: labels.abilities },
    { value: auraCount, label: labels.auras },
    { value: activeCount, label: labels.actives },
];

const kinds = [
    { key: "all", label: labels.all },
    { key: "passive", label: labels.passive },
    { key: "aura", label: labels.aura },
    { key: "active", label: labels.active },
];

const searchText = (ability: (typeof abilities)[number]) =>
    [
        ability.name,
        lang === "ru" ? ability.descriptionRu : ability.description,
        kindLabel(ability.kind),
        ability.units.map((u) => `${u.name} ${u.faction} ${localizedFactionName(lang, u.faction)}`).join(" "),
    ]
        .join(" ")
        .toLowerCase();
---

<section class="subhero abilities-subhero">
    <div class="page-shell abilities-hero-shell">
        <div class="abilities-hero-copy">
            <p class="eyebrow">{page.eyebrow}</p>
            <h1>{page.title}</h1>
            <p>{page.description}</p>
        </div>
        <div class="abilities-summary" aria-label={labels.eyebrow}>
            {
                summaryStats.map((item) => (
                    <div>
                        <strong>{item.value}</strong>
                        <span>{item.label}</span>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<section class="section abilities-section">
    <div class="page-shell">
        <div class="abilities-controls">
            <label class="ability-search">
                <span>{labels.search}</span>
                <input data-ability-search type="search" autocomplete="off" placeholder={labels.searchPlaceholder} />
            </label>

            <div class="abilities-toolbar" role="tablist" aria-label={labels.filter}>
                {
                    kinds.map((k) => (
                        <button
                            class={`kind-pill${k.key === "all" ? " active" : ""}`}
                            data-kind={k.key}
                            type="button"
                            aria-pressed={k.key === "all" ? "true" : "false"}
                        >
                            {k.label}
                        </button>
                    ))
                }
            </div>
        </div>

        <div class="abilities-grid" data-abilities-grid>
            {
                abilities.map((ability) => (
                    <article
                        class="ability-card"
                        data-kind={ability.kind}
                        data-search={searchText(ability)}
                    >
                        <header class="ability-card-head">
                            <img
                                class="ability-card-icon"
                                src={ability.icon}
                                alt=""
                                width="64"
                                height="64"
                                loading="lazy"
                                onerror="this.onerror=null;this.style.visibility='hidden'"
                            />
                            <div class="ability-card-title">
                                <h2>{ability.name}</h2>
                                <span class={`ability-kind ${ability.kind}`}>{kindLabel(ability.kind)}</span>
                            </div>
                        </header>
                        <p class="ability-card-desc">
                            {lang === "ru" ? ability.descriptionRu : ability.description}
                        </p>
                        <div class="ability-card-units">
                            <span class="ability-used-by">
                                {labels.usedBy} · {ability.units.length}
                            </span>
                            <div class="ability-unit-chips">
                                {ability.units.map((u) => (
                                    <a
                                        class="ability-unit-chip"
                                        href={`${unitsHref}?faction=${u.faction.toLowerCase()}`}
                                        style={`--faction: ${factionColors[u.faction]}`}
                                        title={`${u.name} · ${localizedFactionName(lang, u.faction)}`}
                                    >
                                        <img
                                            src={u.icon}
                                            alt=""
                                            width="34"
                                            height="34"
                                            loading="lazy"
                                            onerror="this.onerror=null;this.src='/assets/images/units/units/unknown_creature_512.webp'"
                                        />
                                        <span>{u.name}</span>
                                    </a>
                                ))}
                            </div>
                        </div>
                    </article>
                ))
            }
        </div>

        <p class="abilities-empty" data-abilities-empty hidden>{labels.empty}</p>
    </div>
</section>

<script>
    const cards = Array.from(document.querySelectorAll<HTMLElement>(".ability-card"));
    const pills = Array.from(document.querySelectorAll<HTMLButtonElement>(".kind-pill"));
    const searchInput = document.querySelector<HTMLInputElement>("[data-ability-search]");
    const emptyState = document.querySelector<HTMLElement>("[data-abilities-empty]");
    let activeKind = "all";

    const applyFilters = () => {
        const query = searchInput?.value.trim().toLowerCase() ?? "";
        let visible = 0;
        cards.forEach((card) => {
            const kindMatch = activeKind === "all" || card.dataset.kind === activeKind;
            const searchMatch = !query || (card.dataset.search ?? "").includes(query);
            const show = kindMatch && searchMatch;
            card.hidden = !show;
            if (show) visible += 1;
        });
        if (emptyState) emptyState.hidden = visible > 0;
    };

    const setKind = (kind: string) => {
        activeKind = kind;
        pills.forEach((pill) => {
            const isActive = (pill.dataset.kind ?? "all") === kind;
            pill.classList.toggle("active", isActive);
            pill.setAttribute("aria-pressed", isActive ? "true" : "false");
        });
        applyFilters();
    };

    pills.forEach((pill) => pill.addEventListener("click", () => setKind(pill.dataset.kind ?? "all")));
    searchInput?.addEventListener("input", applyFilters);
</script>

<style>
    .abilities-subhero {
        padding: 34px 0 26px;
    }

    .abilities-hero-shell {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 30px;
        align-items: center;
    }

    .abilities-subhero .eyebrow {
        margin-bottom: 8px;
        color: rgba(242, 199, 93, 0.9);
    }

    .abilities-subhero h1 {
        margin-bottom: 10px;
        font-size: clamp(3.1rem, 7vw, 5.2rem);
        font-weight: 860;
    }

    .abilities-subhero p {
        max-width: 760px;
        margin-bottom: 0;
    }

    .abilities-section {
        padding-top: 18px;
        background:
            linear-gradient(180deg, rgba(251, 244, 232, 0.035), rgba(7, 8, 8, 0) 150px),
            #0b0f12;
    }

    /* The global scroll-reveal (BaseLayout) hides every `.section` at opacity:0 until an
       IntersectionObserver with threshold 0.08 reveals it. The abilities grid is far taller than the
       viewport, so that ratio is never reached and the whole catalogue would stay invisible
       ("abilities not loading"). Force this section visible regardless of the reveal gate. */
    :global(html.reveal-on) .abilities-section {
        opacity: 1 !important;
        transform: none !important;
    }

    .abilities-summary {
        display: flex;
        align-items: center;
        gap: 20px;
        min-width: 0;
    }

    .abilities-summary div {
        display: grid;
        gap: 2px;
        min-width: 78px;
        padding-left: 18px;
        border-left: 1px solid rgba(251, 244, 232, 0.22);
    }

    .abilities-summary div:first-child {
        padding-left: 0;
        border-left: 0;
    }

    .abilities-summary strong {
        color: var(--ink-strong);
        font-size: 1.85rem;
        line-height: 1;
    }

    .abilities-summary span {
        color: rgba(251, 244, 232, 0.66);
        font-size: 0.78rem;
        font-weight: 820;
        text-transform: uppercase;
    }

    .abilities-controls {
        display: grid;
        grid-template-columns: minmax(260px, 0.42fr) minmax(0, 1fr);
        gap: 10px 18px;
        align-items: center;
        margin-bottom: 22px;
        padding: 2px 0 16px;
        border-bottom: 1px solid rgba(251, 244, 232, 0.14);
    }

    .ability-search {
        display: grid;
        gap: 5px;
    }

    .ability-search span {
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 760;
    }

    .ability-search input {
        width: 100%;
        min-height: 42px;
        border: 0;
        border-bottom: 1px solid rgba(251, 244, 232, 0.24);
        border-radius: 0;
        background: transparent;
        color: var(--ink);
        font: inherit;
        padding: 8px 0;
        outline: none;
    }

    .ability-search input:focus {
        border-color: rgba(242, 199, 93, 0.72);
    }

    .abilities-toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        justify-content: flex-end;
    }

    .kind-pill {
        display: inline-flex;
        align-items: center;
        min-height: 34px;
        padding: 5px 12px;
        border: 0;
        border-bottom: 2px solid transparent;
        border-radius: 0;
        background: transparent;
        color: var(--muted);
        font: inherit;
        font-size: 0.9rem;
        font-weight: 780;
        cursor: pointer;
        transition:
            color 0.15s ease,
            border-color 0.15s ease;
    }

    .kind-pill:hover {
        color: var(--ink);
    }

    .kind-pill.active {
        border-color: rgba(242, 199, 93, 0.78);
        color: var(--ink);
    }

    .abilities-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(330px, 1fr));
        gap: 18px;
    }

    .ability-card {
        display: grid;
        gap: 14px;
        align-content: start;
        padding: 18px;
        border: 1px solid var(--line);
        border-radius: 10px;
        background: var(--surface);
        box-shadow: 0 14px 34px rgba(0, 0, 0, 0.22);
    }

    .ability-card[hidden] {
        display: none;
    }

    .ability-card-head {
        display: grid;
        grid-template-columns: 64px minmax(0, 1fr);
        gap: 14px;
        align-items: center;
    }

    .ability-card-icon {
        width: 64px;
        height: 64px;
        border-radius: 10px;
        background: #0c0b09;
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.35);
    }

    .ability-card-title {
        display: grid;
        gap: 6px;
        min-width: 0;
    }

    .ability-card-title h2 {
        margin: 0;
        font-size: 1.2rem;
        line-height: 1.15;
        color: var(--ink);
    }

    .ability-kind {
        justify-self: start;
        padding: 2px 9px;
        border-radius: 999px;
        background: rgba(251, 244, 232, 0.1);
        color: var(--muted);
        font-size: 0.68rem;
        font-weight: 820;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }

    .ability-kind.aura {
        background: rgba(224, 176, 74, 0.16);
        color: var(--gold);
    }

    .ability-kind.active {
        background: rgba(78, 163, 110, 0.18);
        color: var(--green);
    }

    .ability-card-desc {
        margin: 0;
        color: rgba(251, 244, 232, 0.82);
        font-size: 0.92rem;
        line-height: 1.45;
        white-space: pre-line;
    }

    .ability-card-units {
        display: grid;
        gap: 9px;
        padding-top: 12px;
        border-top: 1px solid var(--line);
    }

    .ability-used-by {
        color: var(--muted);
        font-size: 0.74rem;
        font-weight: 820;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }

    .ability-unit-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
    }

    .ability-unit-chip {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 4px 10px 4px 4px;
        border: 1px solid var(--line);
        border-left: 2px solid color-mix(in srgb, var(--faction, var(--gold)) 70%, transparent);
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.25);
        color: rgba(251, 244, 232, 0.86);
        font-size: 0.82rem;
        font-weight: 720;
        text-decoration: none;
        transition:
            border-color 0.15s ease,
            background 0.15s ease;
    }

    .ability-unit-chip:hover {
        border-color: color-mix(in srgb, var(--faction, var(--gold)) 60%, rgba(251, 244, 232, 0.3));
        background: rgba(0, 0, 0, 0.4);
    }

    .ability-unit-chip img {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        object-fit: cover;
        object-position: center top;
        background: #0b0d0f;
    }

    .abilities-empty {
        margin: 24px 0 0;
        padding: 22px;
        border: 1px dashed var(--line-strong);
        border-radius: 8px;
        color: var(--muted);
        text-align: center;
    }

    @media (max-width: 640px) {
        .abilities-hero-shell,
        .abilities-controls {
            grid-template-columns: 1fr;
        }

        .abilities-subhero h1 {
            font-size: 2.35rem;
        }

        .abilities-summary {
            justify-content: space-between;
            gap: 8px;
        }

        .abilities-summary div {
            min-width: 0;
            padding-left: 10px;
        }

        .abilities-toolbar {
            justify-content: flex-start;
            overflow-x: auto;
            flex-wrap: nowrap;
        }

        .kind-pill {
            flex: 0 0 auto;
        }

        .abilities-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
