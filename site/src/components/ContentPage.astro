---
import { content, contractAddress, links, type Language, type PageSlug } from "../lib/site-data";
import { localizedFactionName } from "../lib/localization";

interface Props {
    lang: Language;
    slug: PageSlug;
}

const { lang, slug } = Astro.props;
const copy = content[lang];
const page = copy.pages[slug];
const legalDoc =
    slug === "terms-of-service" ? copy.legal.terms : slug === "privacy-policy" ? copy.legal.privacy : undefined;
const labels =
    lang === "ru"
        ? {
              highlights: "ключевые изменения",
              lastUpdated: "Последнее обновление",
              rosterRelease: "Ростер релиз-кандидата",
          }
        : {
              highlights: "highlights",
              lastUpdated: "Last Updated",
              rosterRelease: "Release-candidate roster",
          };
const formatRosterAbilities = (abilities: string) =>
    lang === "ru" ? abilities.replace(/; spells:/g, "; заклинания:") : abilities;
---

<section class="subhero">
    <div class="page-shell">
        <p class="eyebrow">{page.eyebrow}</p>
        <h1>{page.title}</h1>
        <p>{page.description}</p>
    </div>
</section>

{
    slug === "token" && (
        <section class="section">
            <div class="page-shell token-page">
                <div class="section-heading">
                    <p class="eyebrow">{copy.token.eyebrow}</p>
                    <h2>{copy.token.title}</h2>
                    <p>{copy.token.body}</p>
                </div>

                <div class="contract-box wide">
                    <span>{copy.token.contractLabel}</span>
                    <code>{contractAddress}</code>
                </div>

                <div class="token-links">
                    {copy.token.links.map((link) => (
                        <a class="button secondary" href={link.href} target="_blank" rel="noopener">
                            {link.label}
                        </a>
                    ))}
                </div>

                <div class="allocation-list large">
                    {copy.token.allocation.map((item) => (
                        <article class="allocation-item" style={`--bar-value: ${item.value}%`}>
                            <div class="allocation-title">
                                <h3>{item.label}</h3>
                                <strong>{item.value}%</strong>
                            </div>
                            <div class="allocation-bar" aria-hidden="true"><span></span></div>
                            <p>{item.description}</p>
                        </article>
                    ))}
                </div>

                <div class="utility-list">
                    {copy.token.utility.map((item) => <p>{item}</p>)}
                </div>
            </div>
        </section>
    )
}

{
    slug === "patches" && (
        <section class="section">
            <div class="page-shell patch-list">
                {(copy.patches ?? []).map((patch) => (
                    <article class="patch-item">
                        <div class="patch-meta">
                            <strong>{patch.version}</strong>
                            <time>{patch.date}</time>
                            {patch.href && (
                                <a href={patch.href} target="_blank" rel="noopener">
                                    {patch.commit}
                                </a>
                            )}
                        </div>
                        <div class="patch-body">
                            <div class="patch-heading">
                                <h2>{patch.title}</h2>
                                <p>{patch.impact}</p>
                            </div>

                            <div class="patch-stats" aria-label={`${patch.version} ${labels.highlights}`}>
                                {(patch.stats ?? []).map((stat) => (
                                    <div>
                                        <strong>{stat.value}</strong>
                                        <span>{stat.label}</span>
                                    </div>
                                ))}
                            </div>

                            {(patch.sections ?? []).map((section) => (
                                <section class="patch-section-block">
                                    <h3>{section.title}</h3>
                                    <ul>
                                        {(section.items ?? []).map((item) => <li>{item}</li>)}
                                    </ul>
                                </section>
                            ))}

                            {(patch.roster ?? []).length > 0 && (
                                <section class="patch-section-block roster-release">
                                    <h3>{labels.rosterRelease}</h3>
                                    <div class="release-roster-grid">
                                        {(patch.roster ?? []).map((faction) => (
                                            <div class="release-roster-faction">
                                                <h4>{localizedFactionName(lang, faction.faction)}</h4>
                                                <dl>
                                                    {(faction.units ?? []).map((unit) => (
                                                        <>
                                                            <dt>{unit.name}</dt>
                                                            <dd>{formatRosterAbilities(unit.abilities)}</dd>
                                                        </>
                                                    ))}
                                                </dl>
                                            </div>
                                        ))}
                                    </div>
                                </section>
                            )}

                            {patch.closing && <p class="patch-closing">{patch.closing}</p>}
                        </div>
                    </article>
                ))}
            </div>
        </section>
    )
}

{
    slug === "faq" && (
        <section class="section">
            <div class="page-shell faq-list">
                {copy.faq.map((item) => (
                    <details>
                        <summary>{item.question}</summary>
                        <p>{item.answer}</p>
                    </details>
                ))}
            </div>
        </section>
    )
}

{
    slug === "contact-us" && (
        <section class="section contact-section">
            <div class="page-shell split">
                <div class="section-copy">
                    <h2>{copy.contact.headline}</h2>
                    <p>
                        {copy.contact.emailLabel}: <a href={`mailto:${copy.contact.email}`}>{copy.contact.email}</a>
                    </p>
                    <div class="contact-channels">
                        {copy.socials.map((social) => (
                            <a href={social.href} target="_blank" rel="noopener">
                                <img src={social.icon} alt="" width="20" height="20" />
                                {social.name}
                            </a>
                        ))}
                    </div>
                </div>
                <form
                    class="contact-form"
                    action={`mailto:${copy.contact.email}`}
                    method="post"
                    enctype="text/plain"
                >
                    <label>
                        <span>{copy.contact.formName}</span>
                        <input name="name" autocomplete="name" />
                    </label>
                    <label>
                        <span>{copy.contact.formEmail}</span>
                        <input name="email" type="email" autocomplete="email" />
                    </label>
                    <label>
                        <span>{copy.contact.formSubject}</span>
                        <input name="subject" />
                    </label>
                    <label>
                        <span>{copy.contact.formMessage}</span>
                        <textarea name="message" rows="5"></textarea>
                    </label>
                    <button class="button primary" type="submit">{copy.contact.formSubmit}</button>
                </form>
            </div>
        </section>
    )
}

{
    legalDoc && (
        <section class="section legal-section">
            <article class="page-shell legal-doc">
                <p class="updated">
                    <strong>{labels.lastUpdated}:</strong> {legalDoc.updated}
                </p>
                <p class="lead">{legalDoc.intro}</p>
                {legalDoc.sections.map((section) => (
                    <section>
                        <h2>{section.title}</h2>
                        {section.body.map((paragraph) => <p>{paragraph}</p>)}
                    </section>
                ))}
            </article>
        </section>
    )
}
