---
import { content, links, localPath, type Language } from "../lib/site-data";

interface Props {
    lang: Language;
}

const { lang } = Astro.props;
const copy = content[lang];
const socialLinksLabel = lang === "ru" ? "Социальные ссылки" : "Social links";
const playHref = lang === "ru" ? "/ru/play/" : links.play;
---

<footer class="site-footer">
    <div class="footer-inner">
        <div class="footer-brand">
            <img src="/assets/images/home/logo/hocai_logo_96.png" alt="" width="40" height="40" />
            <div>
                <strong>Heroes of Crypto</strong>
                <span>{copy.hero.availability}</span>
            </div>
        </div>

        <div class="footer-links">
            <a href={localPath(lang, "faq")}>{copy.nav.faq}</a>
            <a href={localPath(lang, "contact-us")}>{copy.nav.contact}</a>
            <a href={localPath(lang, "terms-of-service")}>{copy.nav.terms}</a>
            <a href={localPath(lang, "privacy-policy")}>{copy.nav.privacy}</a>
        </div>

        <a class="footer-play" href={playHref}>
            <img src="/assets/icons/navbar/joystick.svg" alt="" width="18" height="18" />
            {copy.hero.primaryCta}
        </a>

        <div class="social-links" aria-label={socialLinksLabel}>
            {
                copy.socials.map((social) => (
                    <a href={social.href} target="_blank" rel="noopener" aria-label={social.name}>
                        <img src={social.icon} alt="" width="20" height="20" />
                    </a>
                ))
            }
        </div>
    </div>
    <p class="footer-copy">&copy; {new Date().getFullYear()} {copy.ui.copyright}</p>
</footer>
