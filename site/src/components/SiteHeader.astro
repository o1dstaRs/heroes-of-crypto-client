---
import { content, languageSwitchPath, links, localPath, type Language } from "../lib/site-data";

interface Props {
    lang: Language;
    currentPath: string;
}

const { lang, currentPath } = Astro.props;
const copy = content[lang];
const navItems = [
    { label: copy.nav.game, href: localPath(lang, "game") },
    { label: copy.nav.units, href: localPath(lang, "units") },
    { label: copy.nav.token, href: localPath(lang, "token") },
    { label: copy.nav.patches, href: localPath(lang, "patches") },
    { label: copy.nav.faq, href: localPath(lang, "faq") },
    { label: copy.nav.contact, href: localPath(lang, "contact-us") },
    { label: copy.nav.login, href: `${localPath(lang, "home")}auth/login/` },
];

const normalizedPath = currentPath.endsWith("/") && currentPath !== "/" ? currentPath.slice(0, -1) : currentPath;
---

<header class="site-header">
    <a class="brand" href={localPath(lang, "game")} aria-label="Heroes of Crypto">
        <img src="/assets/images/home/logo/hocai_logo_96.png" alt="" width="32" height="32" />
        <span>Heroes of Crypto</span>
    </a>

    <nav class="main-nav" aria-label="Main navigation">
        {
            navItems.map((item) => {
                const itemPath = item.href.endsWith("/") && item.href !== "/" ? item.href.slice(0, -1) : item.href;
                const isActive =
                    normalizedPath === itemPath ||
                    (item.href === localPath(lang, "game") && (normalizedPath === "" || normalizedPath === "/ru"));

                return (
                    <a class:list={["nav-link", { active: isActive }]} href={item.href}>
                        {item.label}
                    </a>
                );
            })
        }
        <a class="nav-link external" href={links.proposal} target="_blank" rel="noopener">
            {copy.nav.proposal}
        </a>
        <span class="nav-language" aria-label={copy.ui.language}>
            <a class:list={["language-option", { active: lang === "en" }]} href={languageSwitchPath(currentPath, "en")}>
                {copy.ui.english}
            </a>
            <a class:list={["language-option", { active: lang === "ru" }]} href={languageSwitchPath(currentPath, "ru")}>
                {copy.ui.russian}
            </a>
        </span>
    </nav>

    <div class="header-actions">
        <a class="header-play" href={links.betaApp} target="_blank" rel="noopener">
            <img src="/assets/icons/navbar/joystick.svg" alt="" width="18" height="18" />
            {copy.hero.primaryCta}
        </a>
        <div class="language-switcher" aria-label={copy.ui.language}>
            <a class:list={["language-option", { active: lang === "en" }]} href={languageSwitchPath(currentPath, "en")}>
                {copy.ui.english}
            </a>
            <a class:list={["language-option", { active: lang === "ru" }]} href={languageSwitchPath(currentPath, "ru")}>
                {copy.ui.russian}
            </a>
        </div>
    </div>
</header>
