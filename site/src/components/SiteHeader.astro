---
import corePackage from "../../../game/core/package.json";
import { content, languageSwitchPath, links, localPath, type Language } from "../lib/site-data";

interface Props {
    lang: Language;
    currentPath: string;
}

const { lang, currentPath } = Astro.props;
const copy = content[lang];
const versionLabel = `v${corePackage.version}`;
const mainNavigationLabel = lang === "ru" ? "Основная навигация" : "Main navigation";
const playHref = lang === "ru" ? "/ru/play/" : links.play;
const navItems = [
    { label: copy.nav.game, href: localPath(lang, "game") },
    { label: copy.nav.rules, href: localPath(lang, "rules") },
    { label: copy.nav.blog, href: `${localPath(lang, "home")}blog/` },
    { label: copy.nav.units, href: localPath(lang, "units") },
    { label: copy.nav.abilities, href: localPath(lang, "abilities") },
    { label: copy.nav.token, href: localPath(lang, "token") },
    { label: copy.nav.patches, href: localPath(lang, "patches") },
];

const normalizedPath = currentPath.endsWith("/") && currentPath !== "/" ? currentPath.slice(0, -1) : currentPath;
---

<header class="site-header">
    <div class="brand-lockup">
        <a class="brand" href={localPath(lang, "game")} aria-label="Heroes of Crypto">
            <img src="/assets/images/home/logo/hocai_logo_96.png" alt="" width="32" height="32" />
            <span>Heroes of Crypto</span>
        </a>
        <a class="version-badge" href={localPath(lang, "patches")} aria-label={`${copy.nav.patches} ${versionLabel}`}>
            {versionLabel}
        </a>
    </div>

    <nav class="main-nav" aria-label={mainNavigationLabel}>
        {
            navItems.map((item) => {
                const itemPath = item.href.endsWith("/") && item.href !== "/" ? item.href.slice(0, -1) : item.href;
                const isActive =
                    normalizedPath === itemPath ||
                    (item.href === localPath(lang, "game") && (normalizedPath === "" || normalizedPath === "/ru"));

                return (
                    <a class:list={["nav-link", { active: isActive }]} href={item.href}>
                        {item.label}
                    </a>
                );
            })
        }
        <span class="nav-language" aria-label={copy.ui.language}>
            <a class:list={["language-option", { active: lang === "en" }]} href={languageSwitchPath(currentPath, "en")}>
                {copy.ui.english}
            </a>
            <a class:list={["language-option", { active: lang === "ru" }]} href={languageSwitchPath(currentPath, "ru")}>
                {copy.ui.russian}
            </a>
        </span>
    </nav>

    <div class="header-actions">
        <a class="header-start header-start-primary" href={playHref} aria-label={copy.play.startLabel}>
            <img src="/assets/icons/navbar/joystick.svg" alt="" width="17" height="17" />
            <span>{copy.play.startCta}</span>
        </a>
        <a class="header-login-link" data-auth-login href={`${localPath(lang, "home")}auth/login/`}>
            {copy.nav.login}
        </a>
        <div class="header-account" data-auth-account hidden>
            <a class="header-account-name" data-auth-username href={playHref} aria-label={copy.nav.login}>
                Account
            </a>
            <button type="button" class="header-logout" data-auth-logout data-logout-redirect={localPath(lang, "home")}>
                {copy.nav.logout}
            </button>
        </div>
        <div class="language-switcher" aria-label={copy.ui.language}>
            <a class:list={["language-option", { active: lang === "en" }]} href={languageSwitchPath(currentPath, "en")}>
                {copy.ui.english}
            </a>
            <a class:list={["language-option", { active: lang === "ru" }]} href={languageSwitchPath(currentPath, "ru")}>
                {copy.ui.russian}
            </a>
        </div>
    </div>
</header>

<script>
    import { displayName, getAuthUser, isLoggedIn, logout, onAuthStateChange } from "../lib/auth-state";

    const loginLink = document.querySelector<HTMLElement>("[data-auth-login]");
    const account = document.querySelector<HTMLElement>("[data-auth-account]");
    const usernameEl = document.querySelector<HTMLElement>("[data-auth-username]");
    const logoutBtn = document.querySelector<HTMLButtonElement>("[data-auth-logout]");

    logoutBtn?.addEventListener("click", () => logout(logoutBtn.dataset.logoutRedirect || "/"));

    onAuthStateChange(() => {
        const loggedIn = isLoggedIn();
        if (usernameEl && loggedIn) usernameEl.textContent = displayName(getAuthUser());
        if (loginLink) loginLink.hidden = loggedIn;
        if (account) account.hidden = !loggedIn;
    });
</script>

<style>
    .header-login-link {
        min-width: 88px;
    }

    .header-account {
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

    /* Higher specificity than .header-account so the hidden attribute still wins over display:flex. */
    .header-account[hidden] {
        display: none;
    }

    .header-account-name {
        max-width: 160px;
        overflow: hidden;
        color: var(--gold, #f2c75d);
        font-weight: 700;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .header-logout {
        padding: 6px 10px;
        border: 1px solid var(--line, rgba(255, 255, 255, 0.16));
        border-radius: 8px;
        background: transparent;
        color: inherit;
        font: inherit;
        font-size: 0.82rem;
        cursor: pointer;
        transition:
            border-color 0.18s ease,
            background 0.18s ease;
    }

    .header-logout:hover {
        border-color: rgba(242, 199, 93, 0.56);
        background: rgba(242, 199, 93, 0.1);
    }

    @media (max-width: 720px) {
        .header-login-link {
            display: none;
        }

        .header-account-name {
            display: none;
        }

        .header-start-primary {
            display: inline-flex;
            min-height: 34px;
            max-width: none;
            padding: 8px 12px;
            font-size: 0.84rem;
        }
    }
</style>
