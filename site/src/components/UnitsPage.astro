---
import { content, type Language } from "../lib/site-data";
import { localizedFactionName } from "../lib/localization";
import { abilityCount, factionColors, factionUnits, unitCount, type Unit } from "../lib/units-data";

interface Props {
    lang: Language;
}

const { lang } = Astro.props;
const copy = content[lang];
const ui = copy.units;
const s = ui.stats;

const unitIndex: Unit[] = factionUnits.flatMap((f) => f.units);
const allUnitsDisplay = [...unitIndex]
    .map((unit, dataIndex) => ({ unit, dataIndex }))
    .sort((a, b) => a.unit.name.localeCompare(b.unit.name) || a.unit.faction.localeCompare(b.unit.faction));
const alphaOrder = new Map(allUnitsDisplay.map(({ dataIndex }, order) => [dataIndex, order]));
const serialized = JSON.stringify(
    unitIndex.map((unit) => ({
        ...unit,
        factionLabel: localizedFactionName(lang, unit.faction),
        abilities: unit.abilities.map((ability) => ({
            name: ability.name,
            description: lang === "ru" ? ability.descriptionRu : ability.description,
            icon: ability.icon,
            isAura: ability.isAura,
            isCastable: ability.isCastable,
            isStackPowered: ability.isStackPowered,
        })),
    })),
);
const labels =
    lang === "ru"
        ? {
              eyebrow: "Боевой ростер",
              search: "Поиск юнитов",
              searchPlaceholder: "Имя, фракция, способность...",
              empty: "Юниты не найдены.",
              factionFilter: "Фильтр фракций",
              close: "Закрыть",
              aura: "аура",
              active: "активно",
              stack: "стек",
              summonedOnly: "Только призыв",
              units: "Юнитов",
              factions: "Фракции",
              abilities: "Способности",
              roles: "Роли атак",
              hp: "ЗД",
              atk: "АТК",
              dmg: "УРН",
              levelShort: "Ур.",
              noAbilityShort: "Базовый юнит",
          }
        : {
              eyebrow: "Battle roster",
              search: "Search units",
              searchPlaceholder: "Name, faction, ability...",
              empty: "No units found.",
              factionFilter: "Faction filter",
              close: "Close",
              aura: "aura",
              active: "active",
              stack: "stack",
              summonedOnly: "Summoned-only",
              units: "Units",
              factions: "Factions",
              abilities: "Abilities",
              roles: "Attack roles",
              hp: "HP",
              atk: "ATK",
              dmg: "DMG",
              levelShort: "L",
              noAbilityShort: "Core unit",
          };
const attackLabels =
    lang === "ru"
        ? {
              MELEE: "Ближняя",
              RANGE: "Дальняя",
              MAGIC: "Магия",
              MELEE_MAGIC: "Ближняя / магия",
          }
        : {
              MELEE: "Melee",
              RANGE: "Ranged",
              MAGIC: "Magic",
              MELEE_MAGIC: "Melee / Magic",
          };
const movementLabels =
    lang === "ru"
        ? { WALK: "Пешком", FLY: "Полет", TELEPORT: "Телепорт" }
        : { WALK: "Walk", FLY: "Fly", TELEPORT: "Teleport" };
const summaryStats = [
    { value: unitCount, label: labels.units },
    { value: factionUnits.length, label: labels.factions },
    { value: abilityCount, label: labels.abilities },
];
const attackRoleCounts = unitIndex.reduce<Record<string, number>>((counts, unit) => {
    counts[unit.attackType] = (counts[unit.attackType] ?? 0) + 1;
    return counts;
}, {});

function localizedAttackLabel(value: string) {
    return attackLabels[value as keyof typeof attackLabels] ?? value;
}

function localizedMovementLabel(value: string) {
    return movementLabels[value as keyof typeof movementLabels] ?? value;
}

function factionLabel(faction: string) {
    return localizedFactionName(lang, faction);
}

function abilityLine(unit: Unit) {
    return unit.abilities.length ? unit.abilities.slice(0, 2).map((ability) => ability.name).join(" + ") : labels.noAbilityShort;
}

function unitSearchText(unit: Unit) {
    return [
        unit.name,
        unit.faction,
        factionLabel(unit.faction),
        localizedAttackLabel(unit.attackType),
        localizedMovementLabel(unit.movementType),
        unit.spells.join(" "),
        unit.abilities.map((ability) => ability.name).join(" "),
        unit.summonedOnly ? labels.summonedOnly : "",
    ]
        .join(" ")
        .toLowerCase();
}
---

<section class="subhero units-subhero">
    <div class="page-shell units-hero-shell">
        <div class="units-hero-copy">
            <p class="eyebrow">{copy.pages.units.eyebrow}</p>
            <h1>{copy.pages.units.title}</h1>
            <p>{copy.pages.units.description}</p>
        </div>
        <div class="units-summary" aria-label={labels.eyebrow}>
            {
                summaryStats.map((item) => (
                    <div>
                        <strong>{item.value}</strong>
                        <span>{item.label}</span>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<section class="section units-section">
    <div class="page-shell">
        <div class="units-controls">
            <label class="unit-search">
                <span>{labels.search}</span>
                <input data-unit-search type="search" autocomplete="off" placeholder={labels.searchPlaceholder} />
            </label>

            <div class="units-toolbar" role="tablist" aria-label={labels.factionFilter}>
                <button class="faction-pill active" data-faction="all" type="button" aria-pressed="true">
                    {ui.all}
                </button>
                {
                    factionUnits.map((f) => (
                        <button
                            class="faction-pill"
                            data-faction={f.faction}
                            type="button"
                            style={`--faction: ${f.color}`}
                            aria-pressed="false"
                        >
                            <img src={f.icon} alt="" width="22" height="22" loading="lazy" />
                            <span>{factionLabel(f.faction)}</span>
                            <em>{f.units.length}</em>
                        </button>
                    ))
                }
            </div>
            <div class="role-strip" aria-label={labels.roles}>
                {
                    Object.entries(attackRoleCounts).map(([role, count]) => (
                        <span>
                            <strong>{count}</strong>
                            {localizedAttackLabel(role)}
                        </span>
                    ))
                }
            </div>
        </div>

        <div class="units-grid" data-units-grid>
            {
                allUnitsDisplay.map(({ unit, dataIndex }) => {
                    const attackType = localizedAttackLabel(unit.attackType);
                    const movementType = localizedMovementLabel(unit.movementType);
                    const searchText = unitSearchText(unit);

                    return (
                        <button
                            class="unit-card"
                            data-unit={dataIndex}
                            data-faction={unit.faction}
                            data-alpha-order={alphaOrder.get(dataIndex)}
                            data-faction-order={dataIndex}
                            data-search={searchText}
                            type="button"
                            style={`--faction: ${factionColors[unit.faction]}`}
                            aria-label={`${unit.name}, ${factionLabel(unit.faction)}, ${ui.level} ${unit.level}${unit.summonedOnly ? `, ${labels.summonedOnly}` : ""}`}
                        >
                            <span class="unit-portrait">
                                <img
                                    src={unit.icon}
                                    alt=""
                                    width="512"
                                    height="512"
                                    loading="lazy"
                                    onerror="this.onerror=null;this.src='/assets/images/units/units/unknown_creature_512.webp'"
                                />
                                <span class="unit-level">{labels.levelShort}{unit.level}</span>
                                <span class="unit-attack-type">{attackType}</span>
                            </span>
                            <span class="unit-card-body">
                                <span class="unit-name">{unit.name}</span>
                                <span class="unit-stat-row">
                                    <span><b>{labels.hp}</b>{unit.hp}</span>
                                    <span><b>{labels.atk}</b>{unit.attack}</span>
                                    <span><b>{labels.dmg}</b>{unit.damageMin}-{unit.damageMax}</span>
                                </span>
                                <span class="unit-tags">
                                    <span class="unit-faction" data-faction={unit.faction}>{factionLabel(unit.faction)}</span>
                                    <span>{movementType}</span>
                                    {unit.summonedOnly && <span class="unit-summoned-only">{labels.summonedOnly}</span>}
                                </span>
                                <span class="unit-ability-line">{abilityLine(unit)}</span>
                            </span>
                        </button>
                    );
                })
            }
        </div>

        <p class="units-empty" data-units-empty hidden>{labels.empty}</p>
    </div>
</section>

<dialog class="unit-dialog" id="unit-dialog" aria-labelledby="unit-dialog-name">
    <div class="unit-dialog-inner">
        <button class="unit-dialog-close" type="button" data-close aria-label={labels.close}>×</button>
        <header class="unit-dialog-head">
            <img
                class="unit-dialog-portrait"
                alt=""
                width="256"
                height="256"
                onerror="this.onerror=null;this.src='/assets/images/units/units/unknown_creature_512.webp'"
            />
            <div class="unit-dialog-title">
                <p class="unit-dialog-faction"><img alt="" width="20" height="20" /> <span></span></p>
                <h2 id="unit-dialog-name"></h2>
                <p class="unit-dialog-meta"></p>
            </div>
        </header>

        <div class="unit-dialog-body">
            <dl class="unit-stats">
                <div><dt>{s.hp}</dt><dd data-stat="hp"></dd></div>
                <div><dt>{s.experience}</dt><dd data-stat="experience"></dd></div>
                <div><dt>{s.armor}</dt><dd data-stat="armor"></dd></div>
                <div><dt>{s.attack}</dt><dd data-stat="attack"></dd></div>
                <div><dt>{s.damage}</dt><dd data-stat="damage"></dd></div>
                <div><dt>{s.speed}</dt><dd data-stat="speed"></dd></div>
                <div><dt>{s.steps}</dt><dd data-stat="steps"></dd></div>
                <div><dt>{s.rangeShots}</dt><dd data-stat="rangeShots"></dd></div>
                <div><dt>{s.magicResist}</dt><dd data-stat="magicResist"></dd></div>
                <div><dt>{s.attackType}</dt><dd data-stat="attackType"></dd></div>
                <div><dt>{s.movement}</dt><dd data-stat="movement"></dd></div>
                <div><dt>{s.size}</dt><dd data-stat="size"></dd></div>
            </dl>

            <div class="unit-abilities">
                <h3>{ui.abilities}</h3>
                <ul class="ability-list" data-ability-list></ul>
            </div>

            <div class="unit-spells" data-spells hidden>
                <h3>{ui.spells}</h3>
                <div class="spell-chips" data-spell-chips></div>
            </div>
        </div>
    </div>
</dialog>

<script type="application/json" id="units-data" data-no-abilities={ui.noAbilities} set:html={serialized} />

<script>
    type Unit = {
        name: string;
        faction: string;
        factionLabel?: string;
        level: number;
        size: number;
        experience: number;
        hp: number;
        armor: number;
        attack: number;
        attackType: string;
        damageMin: number;
        damageMax: number;
        speed: number;
        steps: number;
        rangeShots: number;
        shotDistance: number;
        magicResist: number;
        movementType: string;
        spells: string[];
        abilities: {
            name: string;
            description: string;
            icon: string;
            isAura: boolean;
            isCastable: boolean;
            isStackPowered: boolean;
        }[];
        summonedOnly: boolean;
        portrait: string;
        icon: string;
    };

    const LANG = document.documentElement.lang;
    const LEVEL_LABEL = LANG === "ru" ? "Уровень" : "Level";
    const AURA_LABEL = LANG === "ru" ? "аура" : "aura";
    const ACTIVE_LABEL = LANG === "ru" ? "активно" : "active";
    const STACK_LABEL = LANG === "ru" ? "стек" : "stack";
    const SUMMONED_ONLY_LABEL = LANG === "ru" ? "Только призыв" : "Summoned-only";
    const ATTACK_LABEL: Record<string, string> =
        LANG === "ru"
            ? {
                  MELEE: "Ближняя",
                  RANGE: "Дальняя",
                  MAGIC: "Магия",
                  MELEE_MAGIC: "Ближняя / магия",
              }
            : {
                  MELEE: "Melee",
                  RANGE: "Ranged",
                  MAGIC: "Magic",
                  MELEE_MAGIC: "Melee / Magic",
              };
    const MOVE_LABEL: Record<string, string> =
        LANG === "ru" ? { WALK: "Пешком", FLY: "Полет", TELEPORT: "Телепорт" } : { WALK: "Walk", FLY: "Fly", TELEPORT: "Teleport" };
    const FACTION_ICON: Record<string, string> = {
        Chaos: "/assets/images/units/factions/chaos_128.webp",
        Life: "/assets/images/units/factions/life_128.webp",
        Might: "/assets/images/units/factions/might_128.webp",
        Nature: "/assets/images/units/factions/nature_128.webp",
        Death: "/assets/images/units/factions/death_128.webp",
    };
    const FACTION_LABEL: Record<string, string> =
        LANG === "ru"
            ? { Chaos: "Хаос", Life: "Жизнь", Might: "Сила", Nature: "Природа", Death: "Смерть" }
            : { Chaos: "Chaos", Life: "Life", Might: "Might", Nature: "Nature", Death: "Death" };
    const NO_ABILITIES =
        document.getElementById("units-data")?.dataset.noAbilities ?? "No special abilities.";

    const data = JSON.parse(
        document.getElementById("units-data")?.textContent ?? "[]",
    ) as Unit[];

    const dialog = document.getElementById("unit-dialog") as HTMLDialogElement | null;
    if (dialog) {
        const portrait = dialog.querySelector<HTMLImageElement>(".unit-dialog-portrait")!;
        const nameEl = dialog.querySelector<HTMLHeadingElement>("#unit-dialog-name")!;
        const metaEl = dialog.querySelector<HTMLParagraphElement>(".unit-dialog-meta")!;
        const factionImg = dialog.querySelector<HTMLImageElement>(".unit-dialog-faction img")!;
        const factionTxt = dialog.querySelector<HTMLSpanElement>(".unit-dialog-faction span")!;
        const factionP = dialog.querySelector<HTMLParagraphElement>(".unit-dialog-faction")!;
        const abilityList = dialog.querySelector<HTMLUListElement>("[data-ability-list]")!;
        const spellsWrap = dialog.querySelector<HTMLDivElement>("[data-spells]")!;
        const spellChips = dialog.querySelector<HTMLDivElement>("[data-spell-chips]")!;
        const statEls: Record<string, HTMLElement> = {};
        dialog.querySelectorAll<HTMLElement>("[data-stat]").forEach((el) => {
            statEls[el.dataset.stat as string] = el;
        });

        const openUnit = (unit: Unit) => {
            nameEl.textContent = unit.name;
            portrait.src = unit.portrait;
            portrait.alt = unit.name;
            metaEl.textContent = `${LEVEL_LABEL} ${unit.level} · ${ATTACK_LABEL[unit.attackType] ?? unit.attackType} · ${MOVE_LABEL[unit.movementType] ?? unit.movementType}${unit.summonedOnly ? ` · ${SUMMONED_ONLY_LABEL}` : ""}`;
            factionP.style.setProperty("--faction", factionColor(unit.faction));
            factionImg.src = FACTION_ICON[unit.faction] ?? "";
            factionTxt.textContent = unit.factionLabel ?? FACTION_LABEL[unit.faction] ?? unit.faction;

            statEls.hp.textContent = String(unit.hp);
            statEls.experience.textContent = String(unit.experience);
            statEls.armor.textContent = String(unit.armor);
            statEls.attack.textContent = String(unit.attack);
            statEls.damage.textContent = `${unit.damageMin}–${unit.damageMax}`;
            statEls.speed.textContent = String(unit.speed);
            statEls.steps.textContent = String(unit.steps);
            statEls.rangeShots.textContent = unit.rangeShots > 0 ? String(unit.rangeShots) : "—";
            statEls.magicResist.textContent = unit.magicResist > 0 ? `${unit.magicResist}%` : "—";
            statEls.attackType.textContent = ATTACK_LABEL[unit.attackType] ?? unit.attackType;
            statEls.movement.textContent = MOVE_LABEL[unit.movementType] ?? unit.movementType;
            statEls.size.textContent = String(unit.size);

            abilityList.innerHTML = "";
            if (unit.abilities.length === 0) {
                const li = document.createElement("li");
                li.className = "ability-empty";
                li.textContent = NO_ABILITIES;
                abilityList.appendChild(li);
            } else {
                for (const a of unit.abilities) {
                    const li = document.createElement("li");
                    const icon = document.createElement("img");
                    icon.src = a.icon;
                    icon.alt = "";
                    icon.width = 40;
                    icon.height = 40;
                    icon.loading = "lazy";
                    icon.onerror = () => {
                        icon.onerror = null;
                        icon.style.visibility = "hidden";
                    };
                    const body = document.createElement("div");
                    const head = document.createElement("p");
                    head.className = "ability-name";
                    head.textContent = a.name;
                    if (a.isAura) {
                        const tag = document.createElement("span");
                        tag.className = "ability-tag aura";
                        tag.textContent = AURA_LABEL;
                        head.appendChild(tag);
                    }
                    if (a.isCastable) {
                        const tag = document.createElement("span");
                        tag.className = "ability-tag cast";
                        tag.textContent = ACTIVE_LABEL;
                        head.appendChild(tag);
                    }
                    if (a.isStackPowered) {
                        const tag = document.createElement("span");
                        tag.className = "ability-tag stack";
                        tag.textContent = STACK_LABEL;
                        head.appendChild(tag);
                    }
                    const desc = document.createElement("p");
                    desc.className = "ability-desc";
                    desc.textContent = a.description;
                    body.appendChild(head);
                    body.appendChild(desc);
                    li.appendChild(icon);
                    li.appendChild(body);
                    abilityList.appendChild(li);
                }
            }

            spellChips.innerHTML = "";
            const spells = [...new Set(unit.spells.map((sp) => sp.replace(/^[^:]+:/, "")))];
            if (spells.length > 0) {
                for (const sp of spells) {
                    const chip = document.createElement("span");
                    chip.className = "spell-chip";
                    chip.textContent = sp;
                    spellChips.appendChild(chip);
                }
                spellsWrap.hidden = false;
            } else {
                spellsWrap.hidden = true;
            }

            dialog.showModal();
        };

        function factionColor(f: string): string {
            const map: Record<string, string> = {
                Chaos: "#c63d33",
                Life: "#4ea36e",
                Might: "#e0b04a",
                Nature: "#6f9bd6",
                Death: "#8a76bf",
            };
            return map[f] ?? "#e0b04a";
        }

        dialog.addEventListener("click", (e) => {
            const t = e.target as HTMLElement;
            if (t.matches("[data-close]") || t === dialog) {
                dialog.close();
            }
        });
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && dialog.open) dialog.close();
        });

        document.querySelectorAll<HTMLElement>("[data-unit]").forEach((card) => {
            card.addEventListener("click", () => {
                const idx = Number(card.dataset.unit);
                const unit = data[idx];
                if (unit) openUnit(unit);
            });
        });
    }

    const pills = Array.from(document.querySelectorAll<HTMLButtonElement>(".faction-pill"));
    const grid = document.querySelector<HTMLElement>("[data-units-grid]");
    const cards = Array.from(document.querySelectorAll<HTMLElement>(".unit-card"));
    const searchInput = document.querySelector<HTMLInputElement>("[data-unit-search]");
    const emptyState = document.querySelector<HTMLElement>("[data-units-empty]");
    let activeFaction = "all";

    const cardOrder = (card: HTMLElement, key: "alphaOrder" | "factionOrder") =>
        Number(card.dataset[key] ?? "0");

    const syncCardOrder = () => {
        if (!grid) return;

        const orderKey = activeFaction === "all" ? "alphaOrder" : "factionOrder";
        const sortedCards = [...cards].sort((a, b) => cardOrder(a, orderKey) - cardOrder(b, orderKey));
        grid.append(...sortedCards);
    };

    const syncFactionParam = (faction: string) => {
        const url = new URL(window.location.href);
        if (faction && faction !== "all") {
            url.searchParams.set("faction", faction.toLowerCase());
        } else {
            url.searchParams.delete("faction");
        }
        window.history.replaceState(null, "", url);
    };

    const applyFilters = () => {
        const query = searchInput?.value.trim().toLowerCase() ?? "";
        let visibleCount = 0;

        cards.forEach((card) => {
            const factionMatch = activeFaction === "all" || card.dataset.faction === activeFaction;
            const searchMatch = !query || (card.dataset.search ?? "").includes(query);
            const show = factionMatch && searchMatch;
            card.hidden = !show;
            if (show) visibleCount += 1;
        });

        if (emptyState) {
            emptyState.hidden = visibleCount > 0;
        }
    };

    const setActiveFaction = (faction: string) => {
        activeFaction = faction;
        pills.forEach((pill) => {
            const isActive = (pill.dataset.faction ?? "all") === faction;
            pill.classList.toggle("active", isActive);
            pill.setAttribute("aria-pressed", isActive ? "true" : "false");
        });
        syncFactionParam(faction);
        syncCardOrder();
        applyFilters();
    };

    pills.forEach((pill) => {
        pill.addEventListener("click", () => setActiveFaction(pill.dataset.faction ?? "all"));
    });

    const requestedFaction = new URLSearchParams(window.location.search).get("faction")?.trim().toLowerCase() ?? "";
    const matchingPill = pills.find((pill) => (pill.dataset.faction ?? "").toLowerCase() === requestedFaction);
    setActiveFaction(matchingPill ? (matchingPill.dataset.faction ?? "all") : "all");

    searchInput?.addEventListener("input", applyFilters);
</script>

<style>
    .units-subhero {
        padding: 34px 0 26px;
    }

    .units-hero-shell {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 30px;
        align-items: center;
    }

    .units-subhero .eyebrow {
        margin-bottom: 8px;
        color: rgba(242, 199, 93, 0.9);
    }

    .units-subhero h1 {
        margin-bottom: 10px;
        font-size: clamp(3.1rem, 7vw, 5.2rem);
        font-weight: 860;
    }

    .units-subhero p {
        max-width: 760px;
        margin-bottom: 0;
    }

    .units-section {
        padding-top: 18px;
        background:
            linear-gradient(180deg, rgba(251, 244, 232, 0.035), rgba(7, 8, 8, 0) 150px),
            #0b0f12;
    }

    /* The mobile roster is too tall to reach the global reveal observer's 8% threshold. */
    :global(html.reveal-on) .units-section {
        opacity: 1 !important;
        transform: none !important;
    }

    .units-summary {
        display: flex;
        align-items: center;
        gap: 20px;
        min-width: 0;
    }

    .units-summary div {
        display: grid;
        gap: 2px;
        min-width: 78px;
        padding-left: 18px;
        border-left: 1px solid rgba(251, 244, 232, 0.22);
    }

    .units-summary div:first-child {
        padding-left: 0;
        border-left: 0;
    }

    .units-summary strong {
        color: var(--ink-strong);
        font-size: 1.85rem;
        line-height: 1;
    }

    .units-summary span {
        color: rgba(251, 244, 232, 0.66);
        font-size: 0.78rem;
        font-weight: 820;
        text-transform: uppercase;
    }

    .role-strip {
        grid-column: 1 / -1;
        display: flex;
        flex-wrap: wrap;
        gap: 9px;
        align-items: center;
        min-width: 0;
        padding-top: 2px;
    }

    .role-strip span {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        min-height: 30px;
        color: rgba(251, 244, 232, 0.74);
        font-size: 0.84rem;
        font-weight: 780;
    }

    .role-strip span + span {
        padding-left: 9px;
        border-left: 1px solid rgba(251, 244, 232, 0.18);
    }

    .role-strip strong {
        color: var(--gold);
    }

