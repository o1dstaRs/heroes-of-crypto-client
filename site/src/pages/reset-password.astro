---
import AuthPage from "../components/AuthPage.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { content } from "../lib/site-data";

const lang = "en";
const copy = content[lang];
---

<BaseLayout lang={lang} title={copy.auth.resetTitle} description={copy.auth.resetDescription}>
    <AuthPage lang={lang} mode="reset-password" />
</BaseLayout>
