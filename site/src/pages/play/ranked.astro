---
import BaseLayout from "../../layouts/BaseLayout.astro";

const lang = "en";
const isProd =
    import.meta.env.PROD ||
    import.meta.env.VITE_IS_PROD === "true" ||
    import.meta.env.VITE_IS_PROD === true;
const rankedPath = (url: string) => {
    const cleanUrl = url.replace(/\/$/, "");
    return cleanUrl.endsWith("/play") ? cleanUrl : `${cleanUrl}/play`;
};
const configuredGameClientUrls = [
    import.meta.env.VITE_GAME_CLIENT_RANKED,
    import.meta.env.VITE_GAME_CLIENT,
    import.meta.env.VITE_HOST_GAME_CLIENT,
]
    .filter(Boolean)
    .map((url) => rankedPath(String(url)));
const fallbackGameClientUrls = isProd
    ? ["https://game.heroesofcrypto.io/play"]
    : [
          "http://127.0.0.1:5175/play",
          "http://localhost:5175/play",
          "http://127.0.0.1:5174/play",
          "http://localhost:5174/play",
          "http://127.0.0.1:5173/play",
          "http://localhost:5173/play",
      ];
const gameClientUrls = [...new Set([...configuredGameClientUrls, ...fallbackGameClientUrls])];
const fallbackUrl = gameClientUrls[0];
---

<BaseLayout
    lang={lang}
    title="Play Ranked"
    description="Open Heroes of Crypto ranked matchmaking."
>
    <section class="redirect-page">
        <h1>Opening Ranked</h1>
        <p>Redirecting to Heroes of Crypto ranked matchmaking.</p>
        <p><a href={fallbackUrl}>Open ranked</a></p>
    </section>
</BaseLayout>

<script define:vars={{ gameClientUrls }}>
    const localHosts = new Set(["127.0.0.1", "localhost", "::1"]);

    function targetWithToken(url) {
        const token = localStorage.getItem("accessToken");
        const target = new URL(url, window.location.href);

        for (const [key, value] of new URLSearchParams(window.location.search)) {
            target.searchParams.set(key, value);
        }

        if (token) {
            const hashParams = new URLSearchParams(target.hash.startsWith("#") ? target.hash.slice(1) : target.hash);
            hashParams.set("access_token", token);
            target.hash = hashParams.toString();
        }

        return target;
    }

    async function canReach(url) {
        const controller = new AbortController();
        const timeout = window.setTimeout(() => controller.abort(), 700);

        try {
            await fetch(url, {
                cache: "no-store",
                mode: "no-cors",
                signal: controller.signal,
            });
            return true;
        } catch {
            return false;
        } finally {
            window.clearTimeout(timeout);
        }
    }

    async function resolveTarget() {
        for (const url of gameClientUrls) {
            const candidate = targetWithToken(url);
            if (candidate.href === window.location.href) continue;
            if (!localHosts.has(candidate.hostname)) return candidate;
            if (!localHosts.has(window.location.hostname) || await canReach(candidate.href)) return candidate;
        }

        return targetWithToken(gameClientUrls[0]);
    }

    resolveTarget().then((target) => window.location.replace(target.toString()));
</script>

<style>
    .redirect-page {
        min-height: 52vh;
        display: grid;
        align-content: center;
        gap: 12px;
        width: min(720px, calc(100% - 40px));
        margin: 0 auto;
        padding: 64px 0;
    }

    .redirect-page h1 {
        margin: 0;
        font-size: clamp(2rem, 5vw, 4rem);
    }

    .redirect-page p {
        margin: 0;
        color: var(--muted);
    }
</style>
