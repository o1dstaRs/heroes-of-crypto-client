---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const lang = "en";

const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout
    lang={lang}
    title="Heroes of Crypto Blog: Player Guides and Stories"
    description="Read Heroes of Crypto faction guides, positioning tips, board-reading notes, battlefield stories, and community-focused strategy for turn-based tactics players."
>
    <section class="blog-index">
        <div class="page-shell">
            <header class="blog-head">
                <p class="eyebrow">Heroes of Crypto Blog</p>
                <h1>Guides, stories, and battlefield notes</h1>
                <p class="blog-lead">
                    Faction identity, positioning habits, board-reading tips, and player values for
                    commanders who want smarter, fairer matches.
                </p>
            </header>

            <ul class="post-list">
                {
                    posts.map((post) => (
                        <li class="post-card">
                            <a href={`/blog/${post.id}/`} class="post-card-link">
                                <div class="post-card-meta">
                                    <time datetime={post.data.date.toISOString()}>
                                        {post.data.date.toLocaleDateString("en-US", {
                                            year: "numeric",
                                            month: "short",
                                            day: "numeric",
                                            timeZone: "UTC",
                                        })}
                                    </time>
                                    <span class="post-tags">
                                        {post.data.tags.map((tag) => (
                                            <span class="post-tag">{tag}</span>
                                        ))}
                                    </span>
                                </div>
                                <h2>{post.data.title}</h2>
                                <p>{post.data.excerpt}</p>
                                <span class="post-read">Read →</span>
                            </a>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>
</BaseLayout>

<style>
    .blog-index {
        padding: 72px 0 104px;
    }
    .blog-head {
        max-width: 760px;
        margin-bottom: 44px;
    }
    .blog-lead {
        max-width: 720px;
        font-size: 1.12rem;
        color: var(--muted);
    }
    .post-list {
        list-style: none;
        margin: 0;
        padding: 0;
        border-top: 1px solid rgba(215, 170, 75, 0.24);
    }
    .post-card {
        border-bottom: 1px solid rgba(232, 224, 208, 0.1);
        transition: background 0.18s ease, border-color 0.18s ease;
    }
    .post-card:hover {
        background: rgba(215, 170, 75, 0.055);
        border-color: rgba(215, 170, 75, 0.28);
    }
    .post-card-link {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 14px 28px;
        padding: 28px 0;
        align-items: start;
    }
    .post-card-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        grid-column: 1 / -1;
    }
    .post-card-meta time {
        color: var(--gold);
        font-size: 0.84rem;
        font-weight: 700;
    }
    .post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }
    .post-tag {
        color: var(--muted);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }
    .post-card h2 {
        grid-column: 1;
        font-size: clamp(1.25rem, 1.8vw, 1.72rem);
        margin-bottom: 8px;
        transition: color 0.15s ease;
    }
    .post-card:hover h2 {
        color: var(--gold-soft);
    }
    .post-card p {
        grid-column: 1;
        max-width: 760px;
        margin: 0;
        color: var(--muted);
    }
    .post-read {
        grid-column: 2;
        grid-row: 2 / 4;
        align-self: center;
        justify-self: end;
        color: var(--gold-soft);
        font-weight: 700;
        font-size: 0.92rem;
        white-space: nowrap;
    }
    @media (max-width: 720px) {
        .blog-index {
            padding-top: 56px;
        }
        .post-card-link {
            grid-template-columns: 1fr;
            gap: 10px;
            padding: 24px 0;
        }
        .post-read {
            grid-column: 1;
            grid-row: auto;
            align-self: start;
            justify-self: start;
        }
    }
</style>
