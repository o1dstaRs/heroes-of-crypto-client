---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

const lang = "en";

export async function getStaticPaths() {
    // Newest first, matching the blog index ordering.
    const posts = (await getCollection("blog")).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
    return posts.map((post, index) => ({
        params: { slug: post.id },
        props: {
            post,
            // "newer" sits above this post in the list; "older" sits below it.
            newer: index > 0 ? posts[index - 1] : null,
            older: index < posts.length - 1 ? posts[index + 1] : null,
        },
    }));
}

const { post, newer, older } = Astro.props;
const { Content } = await render(post);
const siteOrigin = Astro.site ?? new URL("https://heroesofcrypto.io");
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);
const previewImage = new URL("/assets/images/preview_game.webp", siteOrigin);
const publishedTime = post.data.date.toISOString();
const blogPostStructuredData = {
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.excerpt,
    datePublished: publishedTime,
    dateModified: publishedTime,
    mainEntityOfPage: canonicalURL.toString(),
    image: previewImage.toString(),
    keywords: post.data.tags.join(", "),
    author: {
        "@type": "Organization",
        name: "Old Stars Gaming",
        url: "https://heroesofcrypto.io",
    },
    publisher: {
        "@type": "Organization",
        name: "Old Stars Gaming",
        url: "https://heroesofcrypto.io",
    },
};
---

<BaseLayout
    lang={lang}
    title={post.data.title}
    description={post.data.excerpt}
    ogType="article"
    publishedTime={publishedTime}
    tags={post.data.tags}
    structuredData={blogPostStructuredData}
>
    <article class="blog-post">
        <div class="post-shell">
            <a href="/blog/" class="back-link">← All posts</a>

            <header class="post-header">
                <div class="post-meta">
                    <time datetime={post.data.date.toISOString()}>
                        {
                            post.data.date.toLocaleDateString("en-US", {
                                year: "numeric",
                                month: "long",
                                day: "numeric",
                                timeZone: "UTC",
                            })
                        }
                    </time>
                    <span class="post-tags">
                        {post.data.tags.map((tag) => <span class="post-tag">{tag}</span>)}
                    </span>
                </div>
                <h1>{post.data.title}</h1>
                <p class="post-excerpt">{post.data.excerpt}</p>
            </header>

            <div class="prose">
                <Content />
            </div>

            {
                (older || newer) && (
                    <nav class="post-nav" aria-label="More articles">
                        {older ? (
                            <a href={`/blog/${older.id}/`} class="post-nav-link prev">
                                <span class="post-nav-dir">← Previous</span>
                                <span class="post-nav-title">{older.data.title}</span>
                            </a>
                        ) : (
                            <span class="post-nav-spacer" />
                        )}
                        {newer ? (
                            <a href={`/blog/${newer.id}/`} class="post-nav-link next">
                                <span class="post-nav-dir">Next →</span>
                                <span class="post-nav-title">{newer.data.title}</span>
                            </a>
                        ) : (
                            <span class="post-nav-spacer" />
                        )}
                    </nav>
                )
            }

            <footer class="post-footer">
                <a href="/blog/" class="back-link">← Back to blog</a>
            </footer>
        </div>
    </article>

    <script>
        // Render Mermaid diagrams client-side. Astro/Shiki outputs these as
        // <pre data-language="mermaid"> blocks, while rehype-mermaid may leave
        // <pre class="mermaid"> elements depending on the transform path.
        const mermaidBlocks = document.querySelectorAll(
            'pre.mermaid, pre[data-language="mermaid"], code.language-mermaid',
        );
        if (mermaidBlocks.length > 0) {
            const { default: mermaid } = await import("mermaid");
            mermaid.initialize({
                startOnLoad: false,
                theme: "base",
                themeVariables: {
                    background: "#090b0d",
                    darkMode: true,
                    edgeLabelBackground: "#090b0d",
                    fontFamily: "Inter, sans-serif",
                    lineColor: "#d7aa4b",
                    mainBkg: "#151b1d",
                    nodeBorder: "#d7aa4b",
                    primaryColor: "#151b1d",
                    primaryTextColor: "#f8f2e5",
                    secondaryColor: "#111719",
                    tertiaryColor: "#1f2a2d",
                },
            });
            mermaidBlocks.forEach((block, i) => {
                const text = block.textContent?.trim() || "";
                const diagram = document.createElement("pre");
                diagram.className = "mermaid mermaid-diagram";
                diagram.id = `mermaid-${i}`;
                diagram.textContent = text;

                const target =
                    block.tagName === "CODE" && block.parentElement?.tagName === "PRE"
                        ? block.parentElement
                        : block;
                target.replaceWith(diagram);
            });
            await mermaid.run({ querySelector: "pre.mermaid" });
        }
    </script>
</BaseLayout>

<style is:global>
    .blog-post {
        padding: 56px 0 96px;
    }
    .post-shell {
        max-width: 720px;
        margin-inline: auto;
        width: min(720px, calc(100vw - 32px));
    }
    .back-link {
        display: inline-block;
        margin-bottom: 32px;
        color: var(--muted);
        font-size: 0.9rem;
        font-weight: 600;
        transition: color 0.15s ease;
    }
    .back-link:hover {
        color: var(--gold-soft);
    }
    .post-header {
        margin-bottom: 44px;
        padding-bottom: 30px;
        border-bottom: 1px solid rgba(215, 170, 75, 0.22);
    }
    .post-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }
    .post-meta time {
        color: var(--gold);
        font-size: 0.86rem;
        font-weight: 700;
    }
    .post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }
    .post-tag {
        color: var(--muted);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }
    .post-header h1 {
        margin-bottom: 10px;
        font-size: clamp(1.7rem, 2.2vw + 1rem, 2.5rem);
        line-height: 1.14;
    }
    .post-excerpt {
        font-size: 1.14rem;
        color: var(--muted);
        margin-top: 8px;
    }

    /* Prose — clean, readable, dark-theme. */
    .prose {
        font-size: 1.06rem;
        line-height: 1.72;
        color: var(--ink);
    }
    .prose > * + * {
        margin-top: 1.4em;
    }
    .prose h2 {
        font-size: 1.5rem;
        margin-top: 2.2em;
        margin-bottom: 0.5em;
        color: var(--ink);
    }
    .prose h3 {
        font-size: 1.2rem;
        margin-top: 1.8em;
        margin-bottom: 0.4em;
        color: var(--gold-soft);
    }
    .prose strong {
        color: #fff;
    }
    .prose a {
        color: var(--gold-soft);
        text-decoration: underline;
        text-underline-offset: 2px;
    }
    .prose ul,
    .prose ol {
        padding-left: 1.4em;
    }
    .prose li {
        margin-top: 0.5em;
    }
    .prose blockquote {
        margin-inline: 0;
        padding: 12px 18px;
        border-left: 3px solid var(--gold);
        background: var(--surface);
        border-radius: 0 8px 8px 0;
        color: var(--muted);
        font-style: italic;
    }
    .prose code {
        padding: 2px 6px;
        border-radius: 5px;
        background: var(--surface-2);
        font-size: 0.9em;
        color: var(--gold-soft);
    }
    .prose pre {
        padding: 18px 20px;
        border: 1px solid var(--line);
        border-radius: 12px;
        background: #0a0908;
        overflow-x: auto;
        font-size: 0.9rem;
        line-height: 1.6;
    }
    .prose pre code {
        padding: 0;
        background: none;
        color: #e8e0d0;
    }
    .prose pre.mermaid {
        display: flex;
        justify-content: center;
        padding: 20px;
        border-color: rgba(215, 170, 75, 0.28);
        background: #090b0d;
        font-family: Inter, sans-serif;
        overflow-x: auto;
    }
    .prose pre.mermaid svg {
        display: block;
        width: 100%;
        max-width: 680px;
        height: auto;
        margin-inline: auto;
    }
    .prose table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        border-top: 1px solid rgba(215, 170, 75, 0.24);
        border-bottom: 1px solid rgba(232, 224, 208, 0.1);
        font-size: 0.94rem;
    }
    .prose th,
    .prose td {
        padding: 12px 14px;
        border: 0;
        border-bottom: 1px solid rgba(232, 224, 208, 0.09);
        text-align: left;
        vertical-align: top;
    }
    .prose th {
        color: var(--gold-soft);
        font-weight: 700;
    }
    .prose tr:last-child td {
        border-bottom: 0;
    }
    .prose td {
        color: var(--muted);
    }
    .prose img {
        border-radius: 12px;
        border: 1px solid var(--line);
    }

    /* Mermaid diagrams render as inline SVG; keep them readable. */
    .prose .mermaid,
    .prose svg {
        max-width: 100%;
        height: auto;
    }

    /* Previous / next article navigation. */
    .post-nav {
        margin-top: 56px;
        padding-top: 28px;
        border-top: 1px solid var(--line);
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }
    .post-nav-link {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 16px 18px;
        border: 1px solid var(--line);
        border-radius: 12px;
        background: var(--surface);
        transition:
            border-color 0.15s ease,
            background 0.15s ease,
            transform 0.15s ease;
    }
    .post-nav-link:hover {
        border-color: rgba(215, 170, 75, 0.5);
        background: var(--surface-2);
        transform: translateY(-2px);
    }
    .post-nav-link.next {
        text-align: right;
    }
    .post-nav-dir {
        color: var(--gold);
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }
    .post-nav-title {
        color: var(--ink);
        font-size: 1rem;
        font-weight: 600;
        line-height: 1.35;
    }
    .post-nav-link:hover .post-nav-title {
        color: var(--gold-soft);
    }
    .post-nav-spacer {
        display: block;
    }
    @media (max-width: 560px) {
        .post-nav {
            grid-template-columns: 1fr;
        }
        .post-nav-link.next {
            text-align: left;
        }
    }

    .post-footer {
        margin-top: 56px;
        padding-top: 28px;
        border-top: 1px solid var(--line);
    }
</style>
