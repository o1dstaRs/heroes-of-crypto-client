---
import AbilitiesPage from "../../components/AbilitiesPage.astro";
import ArtifactsPage from "../../components/ArtifactsPage.astro";
import ContentPage from "../../components/ContentPage.astro";
import HomePage from "../../components/HomePage.astro";
import ResearchPage from "../../components/ResearchPage.astro";
import RulesPage from "../../components/RulesPage.astro";
import UnitsPage from "../../components/UnitsPage.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { content, pageSlugs, type PageSlug } from "../../lib/site-data";

export function getStaticPaths() {
    return pageSlugs.map((slug) => ({
        params: { slug },
        props: { slug },
    }));
}

const lang = "ru";
const { slug } = Astro.props as { slug: PageSlug };
const copy = content[lang];
const page = copy.pages[slug];
const researchStructuredData =
    slug === "research"
        ? {
              "@type": "CollectionPage",
              name: "Исследования ИИ Heroes of Crypto",
              description: page.description,
              url: new URL("/ru/research/", Astro.site ?? "https://heroesofcrypto.io").toString(),
              inLanguage: "ru",
              hasPart: {
                  "@type": "TechArticle",
                  headline: "A13 — Inside the Heroes of Crypto v0.8 AI",
                  url: new URL("/research/a13/", Astro.site ?? "https://heroesofcrypto.io").toString(),
                  datePublished: "2026-07-22",
                  inLanguage: "en",
              },
          }
        : undefined;
---

<BaseLayout lang={lang} title={page.title} description={page.description} structuredData={researchStructuredData}>
    {
        slug === "game" ? (
            <HomePage lang={lang} />
        ) : slug === "rules" ? (
            <RulesPage lang={lang} />
        ) : slug === "units" ? (
            <UnitsPage lang={lang} />
        ) : slug === "abilities" ? (
            <AbilitiesPage lang={lang} />
        ) : slug === "artifacts" ? (
            <ArtifactsPage lang={lang} />
        ) : slug === "research" ? (
            <ResearchPage lang={lang} />
        ) : (
            <ContentPage lang={lang} slug={slug} />
        )
    }
</BaseLayout>
