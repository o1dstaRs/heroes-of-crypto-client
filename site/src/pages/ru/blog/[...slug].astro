---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ruBlogPosts, type RuBlogPost } from "../../../lib/blog-ru";

const lang = "ru";

export function getStaticPaths() {
    // Newest first, matching the blog index ordering.
    const posts = [...ruBlogPosts].sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());
    return posts.map((post, index) => ({
        params: { slug: post.id },
        props: {
            post,
            newer: index > 0 ? posts[index - 1] : null,
            older: index < posts.length - 1 ? posts[index + 1] : null,
        },
    }));
}

const { post, newer, older } = Astro.props as {
    post: RuBlogPost;
    newer: RuBlogPost | null;
    older: RuBlogPost | null;
};
const siteOrigin = Astro.site ?? new URL("https://heroesofcrypto.io");
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);
const previewImage = new URL("/assets/images/preview_game.webp", siteOrigin);
const publishedTime = new Date(post.date).toISOString();
const blogPostStructuredData = {
    "@type": "BlogPosting",
    headline: post.title,
    description: post.excerpt,
    datePublished: publishedTime,
    dateModified: publishedTime,
    mainEntityOfPage: canonicalURL.toString(),
    image: previewImage.toString(),
    keywords: post.tags.join(", "),
    author: {
        "@type": "Organization",
        name: "Old Stars Gaming",
        url: "https://heroesofcrypto.io",
    },
    publisher: {
        "@type": "Organization",
        name: "Old Stars Gaming",
        url: "https://heroesofcrypto.io",
    },
};
---

<BaseLayout
    lang={lang}
    title={post.title}
    description={post.excerpt}
    ogType="article"
    publishedTime={publishedTime}
    tags={post.tags}
    structuredData={blogPostStructuredData}
>
    <article class="blog-post">
        <div class="post-shell">
            <a href="/ru/blog/" class="back-link">← Все статьи</a>

            <header class="post-header">
                <div class="post-meta">
                    <time datetime={publishedTime}>
                        {
                            new Date(post.date).toLocaleDateString("ru-RU", {
                                year: "numeric",
                                month: "long",
                                day: "numeric",
                                timeZone: "UTC",
                            })
                        }
                    </time>
                    <span class="post-tags">
                        {post.tags.map((tag) => <span class="post-tag">{tag}</span>)}
                    </span>
                </div>
                <h1>{post.title}</h1>
                <p class="post-excerpt">{post.excerpt}</p>
            </header>

            <div class="prose">
                {
                    post.blocks.map((block) => {
                        if (block.type === "h2") {
                            return <h2>{block.text}</h2>;
                        }

                        if (block.type === "table") {
                            return (
                                <table>
                                    <thead>
                                        <tr>{block.headers.map((header) => <th>{header}</th>)}</tr>
                                    </thead>
                                    <tbody>
                                        {block.rows.map((row) => (
                                            <tr>{row.map((cell) => <td>{cell}</td>)}</tr>
                                        ))}
                                    </tbody>
                                </table>
                            );
                        }

                        return <p>{block.text}</p>;
                    })
                }
            </div>

            {
                (older || newer) && (
                    <nav class="post-nav" aria-label="Другие статьи">
                        {older ? (
                            <a href={`/ru/blog/${older.id}/`} class="post-nav-link prev">
                                <span class="post-nav-dir">← Предыдущая</span>
                                <span class="post-nav-title">{older.title}</span>
                            </a>
                        ) : (
                            <span class="post-nav-spacer" />
                        )}
                        {newer ? (
                            <a href={`/ru/blog/${newer.id}/`} class="post-nav-link next">
                                <span class="post-nav-dir">Следующая →</span>
                                <span class="post-nav-title">{newer.title}</span>
                            </a>
                        ) : (
                            <span class="post-nav-spacer" />
                        )}
                    </nav>
                )
            }

            <footer class="post-footer">
                <a href="/ru/blog/" class="back-link">← Вернуться в блог</a>
            </footer>
        </div>
    </article>
</BaseLayout>

<style is:global>
    .blog-post {
        padding: 56px 0 96px;
    }
    .post-shell {
        max-width: 720px;
        margin-inline: auto;
        width: min(720px, calc(100vw - 32px));
    }
    .back-link {
        display: inline-block;
        margin-bottom: 32px;
        color: var(--muted);
        font-size: 0.9rem;
        font-weight: 600;
        transition: color 0.15s ease;
    }
    .back-link:hover {
        color: var(--gold-soft);
    }
    .post-header {
        margin-bottom: 44px;
        padding-bottom: 30px;
        border-bottom: 1px solid rgba(215, 170, 75, 0.22);
    }
    .post-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }
    .post-meta time {
        color: var(--gold);
        font-size: 0.86rem;
        font-weight: 700;
    }
    .post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }
    .post-tag {
        color: var(--muted);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }
    .post-excerpt {
        font-size: 1.14rem;
        color: var(--muted);
        margin-top: 12px;
    }
    .prose {
        color: var(--text);
        line-height: 1.75;
    }
    .prose h2 {
        margin-top: 42px;
        margin-bottom: 12px;
        font-size: 1.55rem;
    }
    .prose p {
        margin: 0 0 20px;
        color: var(--muted);
    }
    .prose table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        border-top: 1px solid rgba(215, 170, 75, 0.24);
        border-bottom: 1px solid rgba(232, 224, 208, 0.1);
        margin: 28px 0;
        font-size: 0.92rem;
    }
    .prose th,
    .prose td {
        border: 0;
        border-bottom: 1px solid rgba(232, 224, 208, 0.09);
        padding: 12px;
        text-align: left;
        vertical-align: top;
    }
    .prose th {
        color: var(--gold-soft);
        font-weight: 700;
    }
    .prose tr:last-child td {
        border-bottom: 0;
    }
    /* Навигация по статьям (предыдущая / следующая). */
    .post-nav {
        margin-top: 48px;
        padding-top: 24px;
        border-top: 1px solid var(--line);
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }
    .post-nav-link {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 16px 18px;
        border: 1px solid var(--line);
        border-radius: 12px;
        background: var(--surface);
        transition:
            border-color 0.15s ease,
            background 0.15s ease,
            transform 0.15s ease;
    }
    .post-nav-link:hover {
        border-color: rgba(215, 170, 75, 0.5);
        background: var(--surface-2);
        transform: translateY(-2px);
    }
    .post-nav-link.next {
        text-align: right;
    }
    .post-nav-dir {
        color: var(--gold);
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }
    .post-nav-title {
        color: var(--ink);
        font-size: 1rem;
        font-weight: 600;
        line-height: 1.35;
    }
    .post-nav-link:hover .post-nav-title {
        color: var(--gold-soft);
    }
    .post-nav-spacer {
        display: block;
    }
    @media (max-width: 560px) {
        .post-nav {
            grid-template-columns: 1fr;
        }
        .post-nav-link.next {
            text-align: left;
        }
    }

    .post-footer {
        margin-top: 48px;
        padding-top: 24px;
        border-top: 1px solid var(--line);
    }
</style>
