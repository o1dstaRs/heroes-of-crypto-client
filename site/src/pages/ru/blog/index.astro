---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ruBlogPosts } from "../../../lib/blog-ru";

const lang = "ru";
const posts = [...ruBlogPosts].sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());
---

<BaseLayout
    lang={lang}
    title="Блог Heroes of Crypto: гайды и истории для игроков"
    description="Читайте гайды по фракциям Heroes of Crypto, советы по позиции, разбор чтения доски, истории с поля боя и заметки для сообщества."
>
    <section class="blog-index">
        <div class="page-shell">
            <header class="blog-head">
                <p class="eyebrow">Блог Heroes of Crypto</p>
                <h1>Гайды, истории и заметки с поля боя</h1>
                <p class="blog-lead">
                    Характер фракций, позиция, чтение доски и ценности игроков для командиров,
                    которые хотят умнее и честнее выигрывать матчи.
                </p>
            </header>

            <ul class="post-list">
                {
                    posts.map((post) => (
                        <li class="post-card">
                            <a href={`/ru/blog/${post.id}/`} class="post-card-link">
                                <div class="post-card-meta">
                                    <time datetime={new Date(post.date).toISOString()}>
                                        {new Date(post.date).toLocaleDateString("ru-RU", {
                                            year: "numeric",
                                            month: "long",
                                            day: "numeric",
                                            timeZone: "UTC",
                                        })}
                                    </time>
                                    <span class="post-tags">
                                        {post.tags.map((tag) => (
                                            <span class="post-tag">{tag}</span>
                                        ))}
                                    </span>
                                </div>
                                <h2>{post.title}</h2>
                                <p>{post.excerpt}</p>
                                <span class="post-read">Читать →</span>
                            </a>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>
</BaseLayout>

<style>
    .blog-index {
        padding: 72px 0 104px;
    }
    .blog-head {
        max-width: 760px;
        margin-bottom: 44px;
    }
    .blog-lead {
        max-width: 720px;
        font-size: 1.12rem;
        color: var(--muted);
    }
    .post-list {
        list-style: none;
        margin: 0;
        padding: 0;
        border-top: 1px solid rgba(215, 170, 75, 0.24);
    }
    .post-card {
        border-bottom: 1px solid rgba(232, 224, 208, 0.1);
        transition: background 0.18s ease, border-color 0.18s ease;
    }
    .post-card:hover {
        background: rgba(215, 170, 75, 0.055);
        border-color: rgba(215, 170, 75, 0.28);
    }
    .post-card-link {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 14px 28px;
        padding: 28px 0;
        align-items: start;
    }
    .post-card-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        grid-column: 1 / -1;
    }
    .post-card-meta time {
        color: var(--gold);
        font-size: 0.84rem;
        font-weight: 700;
    }
    .post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }
    .post-tag {
        color: var(--muted);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }
    .post-card h2 {
        font-size: clamp(1.25rem, 1.8vw, 1.72rem);
        margin-bottom: 8px;
        transition: color 0.15s ease;
    }
    .post-card:hover h2 {
        color: var(--gold-soft);
    }
    .post-card p {
        max-width: 760px;
        margin: 0;
        color: var(--muted);
    }
    .post-read {
        align-self: center;
        color: var(--gold-soft);
        font-weight: 700;
        font-size: 0.92rem;
        white-space: nowrap;
    }
    @media (max-width: 720px) {
        .blog-index {
            padding-top: 56px;
        }
        .post-card-link {
            grid-template-columns: 1fr;
            gap: 10px;
            padding: 24px 0;
        }
        .post-read {
            align-self: start;
        }
    }
</style>
