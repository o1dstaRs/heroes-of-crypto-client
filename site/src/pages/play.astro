---
import BaseLayout from "../layouts/BaseLayout.astro";

const lang = "en";
const isProd =
    import.meta.env.PROD ||
    import.meta.env.VITE_IS_PROD === "true" ||
    import.meta.env.VITE_IS_PROD === true;
const gameClientUrl =
    import.meta.env.VITE_GAME_CLIENT ||
    import.meta.env.VITE_HOST_GAME_CLIENT ||
    (isProd ? "https://game.heroesofcrypto.io/play" : "http://127.0.0.1:5173/play");
---

<BaseLayout
    lang={lang}
    title="Play"
    description="Open the Heroes of Crypto game client."
>
    <section class="redirect-page">
        <h1>Opening Game Client</h1>
        <p>Redirecting to the Heroes of Crypto client.</p>
        <p><a href={gameClientUrl}>Open game client</a></p>
    </section>
</BaseLayout>

<script define:vars={{ gameClientUrl }}>
    const token = localStorage.getItem("accessToken");

    if (!token) {
        window.location.replace("/auth/login/");
    } else {
        const target = new URL(gameClientUrl, window.location.href);
        const hashParams = new URLSearchParams(target.hash.startsWith("#") ? target.hash.slice(1) : target.hash);
        hashParams.set("access_token", token);
        target.hash = hashParams.toString();
        window.location.replace(target.toString());
    }
</script>

<style>
    .redirect-page {
        min-height: 52vh;
        display: grid;
        align-content: center;
        gap: 12px;
        width: min(720px, calc(100% - 40px));
        margin: 0 auto;
        padding: 64px 0;
    }

    .redirect-page h1 {
        margin: 0;
        font-size: clamp(2rem, 5vw, 4rem);
    }

    .redirect-page p {
        margin: 0;
        color: var(--muted);
    }
</style>
