---
import BaseLayout from "../layouts/BaseLayout.astro";
import { content, links } from "../lib/site-data";

const lang = "en";
const copy = content[lang];
---

<BaseLayout
    lang={lang}
    title="Play Heroes of Crypto"
    description={copy.play.modeBody}
>
    <section class="mode-select-page">
        <img class="mode-select-bg" src="/assets/images/preview_game.webp" alt="" width="1200" height="630" />
        <div class="mode-select-shade"></div>
        <div class="page-shell mode-select-layout">
            <div class="mode-select-copy">
                <p class="eyebrow">{copy.play.startLabel}</p>
                <h1>{copy.play.modeTitle}</h1>
                <p>{copy.play.modeBody}</p>
                <div class="hero-highlights" aria-label={copy.hero.availability}>
                    {copy.hero.highlights.map((item) => <span>{item}</span>)}
                </div>

                <div class="play-account" data-play-account hidden>
                    <p class="play-account-greeting">
                        {copy.play.signedInAs} <strong data-play-username>Player</strong>
                    </p>
                    <dl class="play-account-stats">
                        <div><dt>{copy.play.statWins}</dt><dd data-play-wins>0</dd></div>
                        <div><dt>{copy.play.statLosses}</dt><dd data-play-losses>0</dd></div>
                        <div><dt>{copy.play.statGames}</dt><dd data-play-games>0</dd></div>
                    </dl>
                    <button type="button" class="play-account-logout" data-play-logout>{copy.nav.logout}</button>
                </div>
                <p class="play-account-guest" data-play-guest hidden>
                    {copy.play.guestPrompt} <a href="/auth/login/">{copy.play.guestPromptCta}</a>
                </p>
            </div>

            <div class="mode-card-grid" aria-label={copy.play.startLabel}>
                <a class="mode-card mode-card-ranked" href={links.rankedApp}>
                    <span class="mode-card-top">
                        <span class="mode-card-icon">
                            <img src="/assets/icons/navbar/joystick.svg" alt="" width="28" height="28" />
                        </span>
                        <em>{copy.play.rankedBadge}</em>
                    </span>
                    <strong>{copy.play.rankedCta}</strong>
                    <span>{copy.play.rankedHint}</span>
                </a>
                <a class="mode-card mode-card-sandbox" href={links.sandboxApp}>
                    <span class="mode-card-top">
                        <span class="mode-card-icon">
                            <img src="/assets/icons/navbar/settings.svg" alt="" width="28" height="28" />
                        </span>
                        <em>{copy.play.sandboxBadge}</em>
                    </span>
                    <strong>{copy.play.sandboxCta}</strong>
                    <span>{copy.play.sandboxHint}</span>
                </a>
                <a class="mode-card mode-card-lobbies" href={links.lobbiesApp}>
                    <span class="mode-card-top">
                        <span class="mode-card-icon">
                            <img src="/assets/icons/navbar/joystick.svg" alt="" width="28" height="28" />
                        </span>
                        <em>{copy.play.lobbiesBadge}</em>
                    </span>
                    <strong>{copy.play.lobbiesCta}</strong>
                    <span>{copy.play.lobbiesHint}</span>
                </a>
            </div>
        </div>

        <div class="page-shell lobbies-section">
            <h2 class="lobbies-section-title">{copy.play.lobbiesSectionTitle}</h2>
            <div id="open-lobbies" class="open-lobbies" data-lobbies-app={links.lobbiesApp}>
                <p class="open-lobbies-empty">Loading lobbies…</p>
            </div>
        </div>
    </section>
</BaseLayout>

<script>
    import { LobbyList } from "@heroesofcrypto/common/src/generated/protobuf/v1/messages_reexports";
    import { displayName, getAuthUser, isLoggedIn, logout, onAuthStateChange } from "../lib/auth-state";

    // Reflect the signed-in account on the play hub: greet by name + show ranked record, or nudge a
    // guest to log in. Both blocks ship hidden so neither flashes before we know the session state.
    const accountPanel = document.querySelector<HTMLElement>("[data-play-account]");
    const guestPrompt = document.querySelector<HTMLElement>("[data-play-guest]");
    const playUsername = document.querySelector<HTMLElement>("[data-play-username]");
    const playWins = document.querySelector<HTMLElement>("[data-play-wins]");
    const playLosses = document.querySelector<HTMLElement>("[data-play-losses]");
    const playGames = document.querySelector<HTMLElement>("[data-play-games]");

    document.querySelector<HTMLButtonElement>("[data-play-logout]")?.addEventListener("click", () => logout("/"));

    onAuthStateChange(() => {
        const loggedIn = isLoggedIn();
        if (loggedIn) {
            const user = getAuthUser();
            if (playUsername) playUsername.textContent = displayName(user);
            if (playWins) playWins.textContent = String(user?.wins ?? 0);
            if (playLosses) playLosses.textContent = String(user?.losses ?? 0);
            if (playGames) playGames.textContent = String(user?.total_games_played ?? 0);
        }
        if (accountPanel) accountPanel.hidden = !loggedIn;
        if (guestPrompt) guestPrompt.hidden = loggedIn;
    });

    const isProd =
        import.meta.env.PROD || import.meta.env.VITE_IS_PROD === "true" || import.meta.env.VITE_IS_PROD === true;
    // In dev the matchmaking API runs on :3001 (a separate origin from the Astro site on :4321), so
    // never fall back to the site's own origin — that has no /v1 API and 404s the lobby list.
    const mmBaseUrl =
        import.meta.env.VITE_HOST_MATCHMAKING_API ||
        import.meta.env.VITE_MATCHMAKING_API ||
        (isProd ? "https://mm.heroesofcrypto.io" : "http://localhost:3001");
    const lobbiesEndpoint = `${mmBaseUrl.replace(/\/+$/, "")}${isProd ? "/v1/lobbies" : "/v1/mm/lobbies"}`;

    const escapeHtml = (value: string): string =>
        value.replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c]!);

    const container = document.getElementById("open-lobbies");
    const lobbiesApp = container?.dataset.lobbiesApp ?? "/play/lobbies";

    async function refreshLobbies(): Promise<void> {
        if (!container) return;
        try {
            const res = await fetch(lobbiesEndpoint, { headers: { Accept: "application/octet-stream" } });
            if (!res.ok) throw new Error(String(res.status));
            const bytes = new Uint8Array(await res.arrayBuffer());
            const lobbies = LobbyList.deserializeBinary(bytes).toObject().lobbies ?? [];
            if (lobbies.length === 0) {
                container.innerHTML = '<p class="open-lobbies-empty">No open lobbies right now.</p>';
                return;
            }
            container.innerHTML = lobbies
                .map((lobby: any) => {
                    const host = lobby.host ?? {};
                    const name = escapeHtml(lobby.name || `${host.username ?? "Player"}'s lobby`);
                    const meta = escapeHtml(
                        `${host.username ?? "Player"} · ${host.league ?? "Unranked"} · ${host.rating ?? 0}`,
                    );
                    const href = `${lobbiesApp}?lobby=${encodeURIComponent(lobby.id)}`;
                    return `<a class="open-lobby" href="${href}"><span class="open-lobby-name">${name}</span><span class="open-lobby-meta">${meta}</span></a>`;
                })
                .join("");
        } catch {
            container.innerHTML = '<p class="open-lobbies-empty">Could not load lobbies.</p>';
        }
    }

    void refreshLobbies();
    window.setInterval(() => void refreshLobbies(), 4000);
</script>

<style>
    .mode-select-page {
        position: relative;
        overflow: hidden;
        min-height: calc(100svh - 68px);
        background: #050606;
    }

    .mode-select-bg,
    .mode-select-shade {
        position: absolute;
        inset: 0;
    }

    .mode-select-bg {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.56;
    }

    .mode-select-shade {
        background:
            linear-gradient(90deg, rgba(5, 6, 6, 0.96), rgba(5, 6, 6, 0.72)),
            linear-gradient(180deg, rgba(5, 6, 6, 0.18), #070808);
    }

    .mode-select-layout {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: minmax(0, 0.8fr) minmax(360px, 0.72fr);
        gap: 44px;
        align-items: center;
        min-height: calc(100svh - 68px);
        padding: 64px 0;
    }

    .mode-select-copy p:not(.eyebrow) {
        max-width: 620px;
        color: rgba(251, 244, 232, 0.8);
        font-size: 1.06rem;
    }

    .play-account {
        display: grid;
        gap: 14px;
        max-width: 620px;
        margin-top: 26px;
        padding: 18px 20px;
        border: 1px solid rgba(242, 199, 93, 0.28);
        border-radius: 10px;
        background: linear-gradient(180deg, rgba(242, 199, 93, 0.08), rgba(255, 255, 255, 0.02));
    }

    .play-account[hidden],
    .play-account-guest[hidden] {
        display: none;
    }

    .play-account-greeting {
        margin: 0;
        color: rgba(251, 244, 232, 0.82);
        font-size: 1.02rem;
    }

    .play-account-greeting strong {
        color: var(--gold, #f2c75d);
    }

    .play-account-stats {
        display: flex;
        flex-wrap: wrap;
        gap: 22px;
        margin: 0;
    }

    .play-account-stats div {
        display: grid;
        gap: 2px;
    }

    .play-account-stats dt {
        color: rgba(251, 244, 232, 0.6);
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .play-account-stats dd {
        margin: 0;
        color: #fff;
        font-size: 1.34rem;
        font-weight: 800;
    }

    .play-account-logout {
        justify-self: start;
        padding: 8px 14px;
        border: 1px solid var(--line, rgba(255, 255, 255, 0.16));
        border-radius: 8px;
        background: transparent;
        color: rgba(251, 244, 232, 0.86);
        font: inherit;
        font-size: 0.86rem;
        cursor: pointer;
        transition:
            border-color 0.18s ease,
            background 0.18s ease;
    }

    .play-account-logout:hover {
        border-color: rgba(242, 199, 93, 0.56);
        background: rgba(242, 199, 93, 0.1);
    }

    .play-account-guest {
        max-width: 620px;
        margin-top: 22px;
        color: rgba(251, 244, 232, 0.72);
    }

    .mode-card-grid {
        display: grid;
        gap: 14px;
    }

    .mode-card {
        display: grid;
        gap: 18px;
        min-height: 218px;
        padding: 22px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.085), rgba(255, 255, 255, 0.04));
        box-shadow: var(--shadow);
        transition:
            transform 0.16s ease,
            border-color 0.18s ease,
            background 0.18s ease,
            box-shadow 0.18s ease;
    }

    .mode-card:hover {
        transform: translateY(-2px);
        border-color: rgba(242, 199, 93, 0.56);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.11), rgba(255, 255, 255, 0.05));
    }

    .mode-card-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .mode-card-icon {
        display: grid;
        place-items: center;
        width: 52px;
        height: 52px;
        border-radius: 8px;
        background: rgba(0, 0, 0, 0.26);
    }

    .mode-card em {
        padding: 7px 10px;
        border: 1px solid rgba(242, 199, 93, 0.32);
        border-radius: 8px;
        background: rgba(242, 199, 93, 0.12);
        color: var(--gold);
        font-size: 0.78rem;
        font-style: normal;
        font-weight: 860;
        text-transform: uppercase;
    }

    .mode-card strong {
        color: #fff;
        font-size: 1.42rem;
        line-height: 1.08;
    }

    .mode-card span:last-child {
        color: rgba(251, 244, 232, 0.74);
        font-weight: 650;
        line-height: 1.45;
    }

    .mode-card-ranked {
        border-color: rgba(239, 74, 63, 0.36);
    }

    .mode-card-sandbox {
        border-color: rgba(242, 199, 93, 0.28);
    }

    .mode-card-lobbies {
        border-color: rgba(103, 174, 246, 0.4);
    }

    .lobbies-section {
        position: relative;
        z-index: 1;
        padding: 0 0 64px;
    }

    .lobbies-section-title {
        margin: 0 0 16px;
        color: #fff;
        font-size: 1.4rem;
    }

    .open-lobbies {
        display: grid;
        gap: 10px;
    }

    .open-lobby {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding: 14px 18px;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.035));
        transition:
            transform 0.16s ease,
            border-color 0.18s ease;
    }

    .open-lobby:hover {
        transform: translateY(-2px);
        border-color: rgba(103, 174, 246, 0.56);
    }

    .open-lobby-name {
        color: #fff;
        font-weight: 700;
    }

    .open-lobby-meta {
        color: rgba(251, 244, 232, 0.66);
        font-size: 0.9rem;
    }

    .open-lobbies-empty {
        color: rgba(251, 244, 232, 0.6);
    }

    @media (max-width: 900px) {
        .mode-select-layout {
            grid-template-columns: 1fr;
            align-items: start;
            min-height: auto;
        }
    }

    @media (max-width: 520px) {
        .mode-select-layout {
            padding: 42px 0;
        }

        .mode-card {
            min-height: 0;
            padding: 18px;
        }

        .mode-card strong {
            font-size: 1.2rem;
        }
    }
</style>
