---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { content, type Language } from "../lib/site-data";
import "../styles/global.css";

interface Props {
    lang: Language;
    title?: string;
    description?: string;
    ogType?: "website" | "article";
    publishedTime?: string;
    tags?: string[];
    structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const { lang, title, description, ogType = "website", publishedTime, tags = [], structuredData } = Astro.props;
const copy = content[lang];
const resolvedTitle = title && title !== copy.meta.title ? `${title} | ${copy.meta.title}` : copy.meta.title;
const resolvedDescription = description ?? copy.meta.description;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/assets/images/preview_game.webp", Astro.site);
const schemaCopy =
    lang === "ru"
        ? {
              videoGameDescription:
                  "Бесплатная браузерная пошаговая стратегия с 4 фракциями, 44 юнитами и 74 способностями.",
              genre: ["Стратегия", "Пошаговая тактика", "Тактика"],
              gamePlatform: ["Браузер"],
              applicationCategory: "Игра",
              operatingSystem: "Любая ОС с браузером",
              ogImageAlt: "Поле боя Heroes of Crypto",
          }
        : {
              videoGameDescription:
                  "Free-to-play turn-based strategy game with 4 factions, 44 units, and 74 abilities. Play in your browser.",
              genre: ["Strategy", "Turn-based", "Tactics"],
              gamePlatform: ["Web Browser"],
              applicationCategory: "Game",
              operatingSystem: "Any (Web)",
              ogImageAlt: "Heroes of Crypto battlefield",
          };
const extraStructuredData = structuredData
    ? Array.isArray(structuredData)
        ? structuredData
        : [structuredData]
    : [];

// Structured data: helps search engines understand this is a playable game + org.
const jsonLd = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "VideoGame",
            name: "Heroes of Crypto",
            description: schemaCopy.videoGameDescription,
            genre: schemaCopy.genre,
            gamePlatform: schemaCopy.gamePlatform,
            applicationCategory: schemaCopy.applicationCategory,
            operatingSystem: schemaCopy.operatingSystem,
            offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
            url: canonicalURL.toString(),
        },
        {
            "@type": "Organization",
            name: "Old Stars Gaming",
            url: "https://heroesofcrypto.io",
        },
        ...extraStructuredData,
    ],
};
---

<!doctype html>
<html lang={lang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
        <meta name="theme-color" content="#070808" />
        <meta name="description" content={resolvedDescription} />
        <link rel="canonical" href={canonicalURL} />

        <!-- Open Graph -->
        <meta property="og:type" content={ogType} />
        <meta property="og:site_name" content="Heroes of Crypto" />
        <meta property="og:title" content={resolvedTitle} />
        <meta property="og:description" content={resolvedDescription} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={schemaCopy.ogImageAlt} />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={resolvedTitle} />
        <meta name="twitter:description" content={resolvedDescription} />
        <meta name="twitter:image" content={ogImage} />

        {publishedTime && <meta property="article:published_time" content={publishedTime} />}
        {tags.map((tag) => <meta property="article:tag" content={tag} />)}

        <link rel="preload" as="image" href="/assets/images/preview_game.webp" />
        <link rel="icon" href="/favicon/favicon.ico" sizes="any" />
        <link rel="icon" type="image/png" href="/favicon/favicon-32x32.png" />
        <link rel="apple-touch-icon" href="/favicon/apple-touch-icon.png" />
        <link rel="manifest" href="/manifest.json" />

        <!-- Fonts: Inter (variable) with preconnect + swap to avoid invisible-text flash. -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400..900&display=swap"
            rel="stylesheet"
        />

        <title>{resolvedTitle}</title>
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    </head>
    <body>
        <SiteHeader lang={lang} currentPath={Astro.url.pathname} />
        <main>
            <slot />
        </main>
        <SiteFooter lang={lang} />
    </body>
</html>
