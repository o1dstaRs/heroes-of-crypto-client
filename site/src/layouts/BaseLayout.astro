---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { content, languageSwitchPath, type Language } from "../lib/site-data";
import { abilityCount, unitCount } from "../lib/units-data";
import "../styles/global.css";

interface Props {
    lang: Language;
    title?: string;
    description?: string;
    ogType?: "website" | "article";
    publishedTime?: string;
    tags?: string[];
    structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const { lang, title, description, ogType = "website", publishedTime, tags = [], structuredData } = Astro.props;
const copy = content[lang];
const resolvedTitle = title && title !== copy.meta.title ? `${title} | ${copy.meta.title}` : copy.meta.title;
const resolvedDescription = description ?? copy.meta.description;
const siteOrigin = Astro.site ?? new URL("https://heroesofcrypto.io");
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);
const ogImage = new URL("/assets/images/preview_game.webp", siteOrigin);
// hreflang alternates: every page mirrors EN <-> RU, so map this URL to both and let search
// engines serve the right language (x-default falls back to English).
const enAlternateURL = new URL(languageSwitchPath(Astro.url.pathname, "en"), siteOrigin);
const ruAlternateURL = new URL(languageSwitchPath(Astro.url.pathname, "ru"), siteOrigin);
const ogLocale = lang === "ru" ? "ru_RU" : "en_US";
const ogLocaleAlternate = lang === "ru" ? "en_US" : "ru_RU";
const schemaCopy =
    lang === "ru"
        ? {
              videoGameDescription:
                  `Бесплатная браузерная пошаговая стратегия с 4 фракциями, ${unitCount} юнитами и ${abilityCount} способностями.`,
              genre: ["Стратегия", "Пошаговая тактика", "Тактика"],
              gamePlatform: ["Браузер"],
              applicationCategory: "Игра",
              operatingSystem: "Любая ОС с браузером",
              ogImageAlt: "Поле боя Heroes of Crypto",
          }
        : {
              videoGameDescription:
                  `Free-to-play turn-based strategy game with 4 factions, ${unitCount} units, and ${abilityCount} abilities. Play in your browser.`,
              genre: ["Strategy", "Turn-based", "Tactics"],
              gamePlatform: ["Web Browser"],
              applicationCategory: "Game",
              operatingSystem: "Any (Web)",
              ogImageAlt: "Heroes of Crypto battlefield",
          };
const extraStructuredData = structuredData
    ? Array.isArray(structuredData)
        ? structuredData
        : [structuredData]
    : [];

// Structured data: helps search engines understand this is a playable game + org.
const jsonLd = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "VideoGame",
            name: "Heroes of Crypto",
            description: schemaCopy.videoGameDescription,
            genre: schemaCopy.genre,
            gamePlatform: schemaCopy.gamePlatform,
            applicationCategory: schemaCopy.applicationCategory,
            operatingSystem: schemaCopy.operatingSystem,
            offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
            url: canonicalURL.toString(),
        },
        {
            "@type": "Organization",
            name: "Old Stars Gaming",
            url: "https://heroesofcrypto.io",
        },
        ...extraStructuredData,
    ],
};
---

<!doctype html>
<html lang={lang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
        <meta name="theme-color" content="#070808" />
        <meta name="description" content={resolvedDescription} />
        <link rel="canonical" href={canonicalURL} />

        <!-- Language alternates for EN/RU SEO -->
        <link rel="alternate" hreflang="en" href={enAlternateURL} />
        <link rel="alternate" hreflang="ru" href={ruAlternateURL} />
        <link rel="alternate" hreflang="x-default" href={enAlternateURL} />

        <!-- Open Graph -->
        <meta property="og:type" content={ogType} />
        <meta property="og:site_name" content="Heroes of Crypto" />
        <meta property="og:locale" content={ogLocale} />
        <meta property="og:locale:alternate" content={ogLocaleAlternate} />
        <meta property="og:title" content={resolvedTitle} />
        <meta property="og:description" content={resolvedDescription} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={schemaCopy.ogImageAlt} />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={resolvedTitle} />
        <meta name="twitter:description" content={resolvedDescription} />
        <meta name="twitter:image" content={ogImage} />

        {publishedTime && <meta property="article:published_time" content={publishedTime} />}
        {tags.map((tag) => <meta property="article:tag" content={tag} />)}

        <link rel="preload" as="image" href="/assets/images/preview_game.webp" />
        <link rel="icon" href="/favicon/favicon.ico" sizes="any" />
        <link rel="icon" type="image/png" href="/favicon/favicon-32x32.png" />
        <link rel="apple-touch-icon" href="/favicon/apple-touch-icon.png" />
        <link rel="manifest" href="/manifest.json" />

        <!-- Fonts: Inter (variable) with preconnect + swap to avoid invisible-text flash. -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400..900&display=swap"
            rel="stylesheet"
        />

        <title>{resolvedTitle}</title>
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    </head>
    <body>
        <SiteHeader lang={lang} currentPath={Astro.url.pathname} />
        <main>
            <slot />
        </main>
        <SiteFooter lang={lang} />

        <!-- Progressive scroll-reveal: only hides content once JS confirms support + motion is allowed. -->
        <script is:inline>
            (() => {
                const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
                if (reduce || !("IntersectionObserver" in window)) {
                    return;
                }
                const items = document.querySelectorAll(
                    ".section, .proof-strip, .faction-rail-section, .subhero, .final-cta",
                );
                if (!items.length) {
                    return;
                }
                document.documentElement.classList.add("reveal-on");
                const io = new IntersectionObserver(
                    (entries) => {
                        for (const entry of entries) {
                            if (entry.isIntersecting) {
                                entry.target.classList.add("is-revealed");
                                io.unobserve(entry.target);
                            }
                        }
                    },
                    { rootMargin: "0px 0px -8% 0px", threshold: 0.08 },
                );
                for (const item of items) {
                    item.classList.add("reveal-item");
                    io.observe(item);
                }
            })();
        </script>
    </body>
</html>
